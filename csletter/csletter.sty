\NeedsTeXFormat{LaTeX2e}[2020/10/01]
\ProvidesPackage{csletter}[2026/06/22 v3.1 Letter-formatting package for formal correspondence]

\makeatletter

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Options
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{kvoptions}
\SetupKeyvalOptions{family=csl,prefix=csltr@}

\DeclareStringOption[black]{textcolor}
\DeclareStringOption[blue] {accentcolor}
\DeclareStringOption[gray] {footercolor}
\DeclareStringOption[gray] {headercolor}

\DeclareStringOption[2.5]{topmargin}
\DeclareStringOption[2.5]{bottommargin}
\DeclareStringOption[2.5]{leftmargin}
\DeclareStringOption[2.5]{rightmargin}

\DeclareBoolOption{header}
\DeclareBoolOption{footer}
\DeclareBoolOption{date}
\DeclareBoolOption{logo}
\DeclareBoolOption{signature}

\DeclareStringOption[logo.png]     {logofile}
\DeclareStringOption[signature.png]{signaturefile}

\DeclareStringOption[left]  {headerpos}
\DeclareStringOption[center]{footerpos}
\DeclareStringOption[single]{linespacing}

\ProcessKeyvalOptions*

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Core packages
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{etoolbox}
\RequirePackage{graphicx}
\RequirePackage{iftex}
\RequirePackage{babel}
\RequirePackage[dvipsnames,hyperref,table,x11names]{xcolor}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Fonts
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\ifPDFTeX
	\RequirePackage{ebgaramond}
	\RequirePackage[scaled=.95]{ysabeau}
	\RequirePackage[scaled=.9]{Inconsolata}
\else
	\RequirePackage{fontspec}
	\RequirePackage[warnings-off={mathtools-colon,mathtools-overbracket}]{unicode-math}

	\setmainfont{GaramondLibre}[
		Extension      = .otf,
		UprightFont    = *-Regular,
		ItalicFont     = *-Italic,
		BoldFont       = *-Bold,
		BoldItalicFont = *-BoldItalic,
		SmallCapsFont  = EBGaramond-Medium.otf,
		SmallCapsFeatures = {Letters=SmallCaps}
	]
	\setmathfont{Garamond-Math.otf}[
		AutoFakeBold,
		StylisticSet = {2,6,7,9}
	]
	\setsansfont{Ysabeau}[Scale=MatchLowercase]
	\setmonofont{Inconsolata}[Scale=MatchLowercase]

	\let\mathbfcal\relax
	\let\mathbfscr\relax
	\RequirePackage[cal=cm,bb=stix,scr=dutchcal]{mathalpha}
\fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Page layout
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{geometry}
\geometry{
	top           = \csltr@topmargin cm,
	bottom        = \csltr@bottommargin cm,
	left          = \csltr@leftmargin cm,
	right         = \csltr@rightmargin cm,
	headheight    = 1.25em,
	heightrounded,
	a4paper
}

\setlength{\parindent}{0pt}
\setlength{\parskip}{0.8em}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Colors
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\definecolor{csltext}  {named}{\csltr@textcolor}
\definecolor{cslaccent}{named}{\csltr@accentcolor}
\definecolor{cslheader}{named}{\csltr@headercolor}
\definecolor{cslfooter}{named}{\csltr@footercolor}

\color{csltext}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Line spacing
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\AtBeginDocument{%
	\ifdefstring{\csltr@linespacing}{onehalf}{%
		\RenewDocumentCommand{\baselinestretch}{}{1.5}\selectfont
	}{%
		\ifdefstring{\csltr@linespacing}{double}{%
			\RenewDocumentCommand{\baselinestretch}{}{2.0}\selectfont
		}{%
			\RenewDocumentCommand{\baselinestretch}{}{1.0}\selectfont
		}%
	}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Headers and footers
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{fancyhdr}

\ifcsltr@header
	\pagestyle{fancy}
	\fancyhf{}
	\RenewDocumentCommand{\headrulewidth}{}{0.4pt}
	\ifdefstring{\csltr@headerpos}{left}{%
		\fancyhead[L]{\color{cslheader}\slshape\fromname}%
	}{%
		\ifdefstring{\csltr@headerpos}{right}{%
			\fancyhead[R]{\color{cslheader}\slshape\fromname}%
		}{%
			\fancyhead[C]{\color{cslheader}\slshape\fromname}%
		}%
	}
\fi

\ifcsltr@footer
	\ifcsltr@header\else\pagestyle{fancy}\fi
	\RenewDocumentCommand{\footrulewidth}{}{0.4pt}
	\ifdefstring{\csltr@footerpos}{left}{%
		\fancyfoot[L]{\color{cslfooter}\thepage}%
	}{%
		\ifdefstring{\csltr@footerpos}{right}{%
			\fancyfoot[R]{\color{cslfooter}\thepage}%
		}{%
			\fancyfoot[C]{\color{cslfooter}\thepage}%
		}%
	}
\fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Logo and signature helpers
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\NewDocumentCommand{\csllogo}{}{%
	\ifcsltr@logo
		\ifdefempty{\csltr@logofile}{}{%
			\includegraphics[height=2cm]{\csltr@logofile}%
			\vspace{1em}%
		}%
	\fi
}

\NewDocumentCommand{\cslsignature}{}{%
	\ifcsltr@signature
		\ifdefempty{\csltr@signaturefile}{}{%
			\par\vspace{1em}%
			\includegraphics[height=3em]{\csltr@signaturefile}%
		}%
	\fi
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% References
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{hyperref}
\hypersetup{
	colorlinks = true,
	citecolor  = cslaccent,
	linkcolor  = cslaccent,
	urlcolor   = Peach,
	pdfborder  = {0 0 0}
}

\makeatother
\endinput
