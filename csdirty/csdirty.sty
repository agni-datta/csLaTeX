\if@csdr@loadtheorems
	\PackageInfo{csdirty}{Loaded thmtools for theorem environments}%
	\RequirePackage{amsthm}%
	\RequirePackage{thmtools}%
	\numberwithin{equation}{section}

	\declaretheoremstyle[%
		headfont=\bfseries,
		notefont=\normalfont\scshape,
		bodyfont=\normalfont,
		spaceabove=3pt,
		spacebelow=3pt,
		headpunct=.,
		postheadspace=.5em
	]{csdr@theoremlike}

	\declaretheoremstyle[%
		headfont=\bfseries,
		notefont=\normalfont\scshape,
		bodyfont=\normalfont,
		spaceabove=3pt,
		spacebelow=3pt,
		headpunct=.,
		postheadspace=.5em
	]{csdr@definitionlike}

	\declaretheoremstyle[%
		headfont=\normalfont\scshape,
		bodyfont=\normalfont,
		spaceabove=3pt,
		spacebelow=3pt,
		headpunct=.,
		postheadspace=.5em
	]{csdr@remarklike}

	\declaretheoremstyle[%
		headfont=\normalfont\sffamily,
		bodyfont=\normalfont,
		spaceabove=3pt,
		spacebelow=3pt,
		headpunct=.,
		postheadspace=.5em
	]{csdr@highlightlike}

	\declaretheorem[%
		name=Theorem,
		style=csdr@theoremlike,
		numberwithin=section
	]{theorem}

	\newcommand\csdr@declaretheoremfamily[2]{%
		\forcsvlist{\declaretheorem[sibling=theorem,style=#1]}{#2}%
	}

	\csdr@declaretheoremfamily{csdr@theoremlike}{%
		assertion,assumption,axiom,claim,conclusion,conjecture,corollary,%
		criterion,fact,folklore,hypothesis,lemma,observation,postulate,%
		property,proposition%
	}

	\csdr@declaretheoremfamily{csdr@definitionlike}{%
		application,construction,convention,definition,example,experiment,%
		problem,protocol,result,solution,step,notation%
	}

	\csdr@declaretheoremfamily{csdr@remarklike}{%
		commentary,discussion,exercise,motivation,notationabuse,note,%
		openproblem,question,remark,syntax%
	}

	\csdr@declaretheoremfamily{csdr@highlightlike}{%
		guideline,highlight,important,insight,keypoint,recall,summary,%
		takeaway,tip,warning%
	}

	\declaretheorem[name=Theorem,style=csdr@theoremlike,numbered=no]{theorem*}
	\declaretheorem[name=Lemma,style=csdr@theoremlike,numbered=no]{lemma*}
	\declaretheorem[name=Corollary,style=csdr@theoremlike,numbered=no]{corollary*}
	\declaretheorem[name=Hypothesis,style=csdr@theoremlike,numbered=no]{hypothesis*}
	\declaretheorem[name=Claim,style=csdr@theoremlike,numbered=no]{claim*}
	\declaretheorem[name=Conjecture,style=csdr@theoremlike,numbered=no]{conjecture*}
	\declaretheorem[name=Open Problem,style=csdr@remarklike,numbered=no]{openproblem*}
	\declaretheorem[name=Syntax,style=csdr@remarklike,numbered=no]{syntax*}

\fi

