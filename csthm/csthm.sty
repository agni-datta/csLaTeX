\NeedsTeXFormat{LaTeX2e}[2020/10/01]
\ProvidesPackage{csthm}[2026/06/23 v3.2 Theorem environment suite for theoretical computer science]

\RequirePackage{l3keys2e}
\makeatletter
\ExplSyntaxOn

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Options
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_new:N \g_csthm_fancy_bool
\bool_new:N \g_csthm_normal_bool
\bool_new:N \g_csthm_oldschool_bool

\keys_define:nn { csthm }
{
    normal    .code:n = { \bool_gset_true:N \g_csthm_normal_bool    } ,
    fancy     .code:n = { \bool_gset_true:N \g_csthm_fancy_bool     } ,
    oldschool .code:n = { \bool_gset_true:N \g_csthm_oldschool_bool } ,
    unknown   .code:n = { \PackageWarning{csthm}{Unrecognised~option~`#1'} } ,
}
\ProcessKeysOptions { csthm }

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Core packages
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{amsthm}
\RequirePackage{enumitem}
\RequirePackage{iftex}
\RequirePackage{thmtools}
\RequirePackage[
    skipabove   = 0.75\baselineskip ,
    skipbelow   = 0.75\baselineskip ,
    framemethod = TikZ
]{mdframed}
\RequirePackage[dvipsnames,table,x11names]{xcolor}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Accent color
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\tl_new:N   \g_csthm_accent_tl
\tl_gset:Nn \g_csthm_accent_tl { black }

\NewDocumentCommand \SetAccentColor { m }
{ \tl_gset:Nn \g_csthm_accent_tl {#1} }

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% QED and end-mark symbols
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\NewDocumentCommand \CsthmQED     {}
{ \ensuremath{ \color{\g_csthm_accent_tl} \square   } }
\NewDocumentCommand \CsthmEndMark {}
{ \ensuremath{ \color{\g_csthm_accent_tl} \lrcorner } }
\RenewDocumentCommand{\qedsymbol}{}{\CsthmQED}
\ProvideDocumentCommand{\setqedsymbol}{m}{ \RenewDocumentCommand{\qedsymbol}{}{#1} }
\ProvideDocumentCommand{\settheoremendsymbol}{m}{ \RenewDocumentCommand{\CsthmEndMark}{}{#1} }
\ProvideDocumentCommand{\SetQEDSymbol}{m}{ \setqedsymbol{#1} }
\ProvideDocumentCommand{\SetTheoremEndSymbol}{m}{ \settheoremendsymbol{#1} }

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Case environment
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\newlist{csthm@caselist}{enumerate}{1}
\setlist[csthm@caselist]{ label = \textbf{Case~\arabic*:} , leftmargin = * }

\NewDocumentEnvironment{case}{O{}}
{ \begin{csthm@caselist}[#1] }
{ \end{csthm@caselist}       }

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Theorem environments
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\tl_new:N \l_csthm_cur_style_tl
\tl_new:N \l_csthm_envkey_tl
\tl_new:N \l_csthm_envname_tl
\seq_new:N \l_csthm_pair_seq

\cs_new_protected:Npn \csthm_declare_one:
{
    \use:e
    {
        \exp_not:N \declaretheorem
        [
            style        = \tl_use:N \l_csthm_cur_style_tl ,
            name         = { \tl_use:N \l_csthm_envname_tl } ,
            numberwithin = section
        ]
        { \tl_use:N \l_csthm_envkey_tl }
        \exp_not:N \declaretheorem
        [
            style      = \tl_use:N \l_csthm_cur_style_tl ,
            name       = { \tl_use:N \l_csthm_envname_tl } ,
            unnumbered
        ]
        { \tl_use:N \l_csthm_envkey_tl * }
    }
}

\cs_new_protected:Npn \csthm_declare_list:nn #1 #2
{
    \tl_set:Nn \l_csthm_cur_style_tl {#1}
    \clist_map_inline:nn {#2}
    {
        \seq_set_split:Nnn \l_csthm_pair_seq { / } { ##1 }
        \tl_set:Nx \l_csthm_envkey_tl  { \seq_item:Nn \l_csthm_pair_seq {1} }
        \tl_set:Nx \l_csthm_envname_tl { \seq_item:Nn \l_csthm_pair_seq {2} }
        \csthm_declare_one:
    }
}

\cs_new_protected:Npn \csthm_declare_envs:
{
    \csthm_declare_list:nn { csthm@thmstyle }
    {
        theorem/Theorem,%
        assertion/Assertion,%
        assumption/Assumption,%
        axiom/Axiom,%
        claim/Claim,%
        conclusion/Conclusion,%
        conjecture/Conjecture,%
        corollary/Corollary,%
        fact/Fact,%
        folklore/Folklore,%
        hypothesis/Hypothesis,%
        lemma/Lemma,%
        postulate/Postulate,%
        property/Property,%
        proposition/Proposition%
    }
    \csthm_declare_list:nn { csthm@defstyle }
    {
        application/Application,%
        construction/Construction,%
        convention/Convention,%
        definition/Definition,%
        experiment/Experiment,%
        notation/Notation,%
        openproblem/Open~Problem,%
        problem/Problem,%
        protocol/Protocol,%
        result/Result%
    }
    \csthm_declare_list:nn { csthm@remarkstyle }
    {
        commentary/Commentary,%
        contribution/Contribution,%
        example/Example,%
        exercise/Exercise,%
        motivation/Motivation,%
        notationabuse/Notation~Abuse,%
        note/Note,%
        observation/Observation,%
        question/Question,%
        remark/Remark%
    }
    \csthm_declare_list:nn { csthm@hltstyle }
    {
        guideline/Guideline,%
        highlight/Highlight,%
        important/Important,%
        insight/Insight,%
        keypoint/Key~Point,%
        recall/Recall,%
        summary/Summary,%
        takeaway/Takeaway,%
        tip/Tip,%
        warning/Warning%
    }
    \NewDocumentEnvironment{proofsketch}{o}
    {
        \IfNoValueTF{##1}
        { \begin{proof}[Proof~(Sketch)] }
        { \begin{proof}[Proof~(Sketch~##1)] }
    }
    { \end{proof} }
    \NewDocumentEnvironment{proofidea}{o}
    {
        \IfNoValueTF{##1}
        { \begin{proof}[Proof~(Idea)] }
        { \begin{proof}[Proof~(Idea~##1)] }
    }
    { \end{proof} }
    \NewDocumentEnvironment{proofofclaim}{o}
    {
        \IfNoValueTF{##1}
        { \begin{proof}[Proof~of~Claim] }
        { \begin{proof}[Proof~of~Claim~(##1)] }
    }
    { \end{proof} }
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Style: normal
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\cs_new_protected:Npn \csthm_setup_normal:
{
    \mdfdefinestyle { csthm@ruled }
    {
        linewidth         = 0.5pt ,
        topline           = true  ,
        bottomline        = true  ,
        leftline          = false ,
        rightline         = false ,
        innertopmargin    = 7.5pt ,
        innerbottommargin = 7.5pt ,
        innerleftmargin   = 0pt   ,
        innerrightmargin  = 0pt   ,
        skipabove         = 0.75\baselineskip ,
        skipbelow         = 0.75\baselineskip
    }
    \declaretheoremstyle
    [
        headfont      = \scshape ,
        notefont      = \normalfont ,
        bodyfont      = \normalfont ,
        headpunct     = {.} ,
        spaceabove    = 0pt ,
        spacebelow    = 0pt ,
        postheadspace = 0.5em ,
        mdframed      = { style = csthm@ruled } ,
        qed           = \CsthmEndMark
    ]{ csthm@thmstyle }
    \declaretheoremstyle
    [
        headfont      = \scshape ,
        notefont      = \normalfont ,
        bodyfont      = \normalfont ,
        headpunct     = {.} ,
        spaceabove    = 0pt ,
        spacebelow    = 0pt ,
        postheadspace = 0.5em ,
        mdframed      = { style = csthm@ruled } ,
        qed           = \CsthmEndMark
    ]{ csthm@defstyle }
    \declaretheoremstyle
    [
        headfont      = \scshape ,
        notefont      = \normalfont ,
        bodyfont      = \normalfont ,
        headpunct     = {.} ,
        spaceabove    = 0pt ,
        spacebelow    = 0pt ,
        postheadspace = 0.5em ,
        mdframed      = { style = csthm@ruled } ,
        qed           = \CsthmEndMark
    ]{ csthm@remarkstyle }
    \declaretheoremstyle
    [
        headfont      = \sffamily ,
        notefont      = \normalfont ,
        bodyfont      = \normalfont\sffamily ,
        headpunct     = {.} ,
        spaceabove    = 0pt ,
        spacebelow    = 0pt ,
        postheadspace = 0.5em ,
        mdframed      = { style = csthm@ruled } ,
        qed           = \CsthmEndMark
    ]{ csthm@hltstyle }
    \declaretheoremstyle
    [
        headfont      = \scshape ,
        notefont      = \normalfont ,
        bodyfont      = \normalfont ,
        headpunct     = {.} ,
        spaceabove    = 0pt ,
        spacebelow    = 0pt ,
        postheadspace = 0.5em ,
        numbered      = no ,
        qed           = \CsthmQED
    ]{ csthm@proofstyle }
    \csthm_declare_envs:
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Style: fancy
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\cs_new_protected:Npn \csthm_setup_fancy:
{
    \colorlet { csthm@thmcolor    } { SeaGreen4   }
    \colorlet { csthm@defcolor    } { RoyalBlue2  }
    \colorlet { csthm@remarkcolor } { Aquamarine4 }
    \colorlet { csthm@hltcolor    } { DeepPink4   }

    \cs_new_protected:Npn \csthm_fancystyle:nnn ##1 ##2 ##3
    {
        \declaretheoremstyle
        [
            headfont      = \sffamily\color{##2} ,
            notefont      = \sffamily\color{##2} ,
            bodyfont      = ##3 ,
            headpunct     = {.} ,
            spaceabove    = 0pt ,
            spacebelow    = 0pt ,
            postheadspace = 0.5em ,
            mdframed      =
                {
                    linewidth       = 2pt   ,
                    topline         = false ,
                    bottomline      = false ,
                    rightline       = false ,
                    leftline        = true  ,
                    linecolor       = ##2   ,
                    backgroundcolor = ##2!5
                }
        ]{ ##1 }
    }
    \csthm_fancystyle:nnn { csthm@thmstyle }    { csthm@thmcolor    } { \normalfont }
    \csthm_fancystyle:nnn { csthm@defstyle }    { csthm@defcolor    } { \normalfont }
    \csthm_fancystyle:nnn { csthm@remarkstyle } { csthm@remarkcolor } { \normalfont }
    \csthm_fancystyle:nnn { csthm@hltstyle }    { csthm@hltcolor    } { \normalfont\sffamily }
    \declaretheoremstyle
    [
        headfont      = \scshape\color{csthm@thmcolor} ,
        bodyfont      = \normalfont ,
        headpunct     = {.} ,
        spaceabove    = 0pt ,
        spacebelow    = 0pt ,
        postheadspace = 0.5em ,
        numbered      = no ,
        qed           = \CsthmQED
    ]{ csthm@proofstyle }
    \csthm_declare_envs:
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Style: oldschool
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\cs_new_protected:Npn \csthm_setup_oldschool:
{
    \declaretheoremstyle
    [
        headfont      = \scshape ,
        notefont      = \normalfont ,
        bodyfont      = \normalfont ,
        headpunct     = {.} ,
        spaceabove    = \topsep ,
        spacebelow    = \topsep ,
        postheadspace = 0.5em
    ]{ csthm@thmstyle }
    \declaretheoremstyle
    [
        headfont      = \scshape ,
        notefont      = \normalfont ,
        bodyfont      = \normalfont ,
        headpunct     = {.} ,
        spaceabove    = \topsep ,
        spacebelow    = \topsep ,
        postheadspace = 0.5em ,
        qed           = \CsthmEndMark
    ]{ csthm@defstyle }
    \declaretheoremstyle
    [
        headfont      = \scshape ,
        notefont      = \normalfont ,
        bodyfont      = \normalfont ,
        headpunct     = {.} ,
        spaceabove    = \topsep ,
        spacebelow    = \topsep ,
        postheadspace = 0.5em ,
        qed           = \CsthmEndMark
    ]{ csthm@remarkstyle }
    \declaretheoremstyle
    [
        headfont      = \sffamily ,
        notefont      = \normalfont ,
        bodyfont      = \normalfont\sffamily ,
        headpunct     = {.} ,
        spaceabove    = \topsep ,
        spacebelow    = \topsep ,
        postheadspace = 0.5em ,
        qed           = \CsthmEndMark
    ]{ csthm@hltstyle }
    \declaretheoremstyle
    [
        headfont      = \scshape ,
        bodyfont      = \normalfont ,
        headpunct     = {.} ,
        spaceabove    = 0pt ,
        spacebelow    = 0pt ,
        postheadspace = 0.5em ,
        numbered      = no ,
        qed           = \CsthmQED
    ]{ csthm@proofstyle }
    \csthm_declare_envs:
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Style dispatch
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_if:NTF \g_csthm_fancy_bool
{ \csthm_setup_fancy: }
{
    \bool_if:NTF \g_csthm_normal_bool
    { \csthm_setup_normal: }
    {
        \bool_if:NTF \g_csthm_oldschool_bool
        { \csthm_setup_oldschool: }
        {
            \PackageInfo{csthm}
            { No~style~option~given;~no~theorem~environments~defined. }
        }
    }
}

