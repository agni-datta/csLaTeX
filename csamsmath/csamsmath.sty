%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% References
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{nameref}
\RequirePackage[
	bookmarksnumbered = true,
	breaklinks        = true,
	citecolor         = SteelBlue4,
	colorlinks        = true,
	hypertexnames     = true,
	linkcolor         = SteelBlue4,
	pagebackref       = true,
	pdfencoding       = auto,
	pdfpagelabels     = true,
	pdfpagelayout     = SinglePage,
	pdfstartview      = FitH,
	pdfusetitle,
	unicode           = true,
	urlcolor          = SteelBlue4
]{hyperref}

\pdfstringdefDisableCommands{%
\def\langle{<}\def\rangle{>}%
\def\lceil{[}\def\rceil{]}%
\def\left{}\def\right{}%
\def\lfloor{[}\def\rfloor{]}%
\def\mathbb#1{#1}%
\def\mathbf#1{#1}%
\def\mathcal#1{#1}%
\def\mathfrak#1{#1}%
\def\mathrm#1{#1}%
\def\mathscr#1{#1}%
\def\mathsf#1{#1}%
\def\mathtt#1{#1}%
\def\operatorname#1{#1}%
\def\text#1{#1}%
\def\var#1{#1}%
}

\RenewDocumentCommand{\backref}{m}{}
\RenewDocumentCommand{\backrefalt}{m m m m}{%
	\ifcase #1\or (Cited on p.~#2).%
	\else (Cited on pp.~#2).%
	\fi
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Title and authors
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{titling}
\RequirePackage[auth-sc]{authblk}

\pretitle{\begin{center}\Large\bfseries}
\posttitle{\end{center}}
\preauthor{\begin{center}\normalsize\scshape}
\postauthor{\end{center}}
\predate{\begin{center}\small\normalfont}
\postdate{\end{center}}

\RenewDocumentCommand{\Authfont}{}{\normalsize\scshape}
\RenewDocumentCommand{\Affilfont}{}{\small\normalfont}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Sectioning
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{titlesec}

\titleformat{\section}
{\normalfont\bfseries\Large}
{\thesection\quad}{0pt}{}[]

\titleformat{\subsection}
{\normalfont\bfseries\large}
{\thesubsection\quad}{0pt}{}[]

\titleformat{\subsubsection}[runin]
{\normalfont\bfseries\normalsize}
{\thesubsubsection.}{0.5em}{}[.]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Theorem environments
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage[most]{tcolorbox}
\RequirePackage[
	framemethod = TikZ ,
	ntheorem ,
	skipabove   = 10pt ,
	skipbelow   = 10pt
]{mdframed}

\numberwithin{equation}{section}

\NewDocumentCommand{\thmendsymb}{}{\ensuremath{\scriptstyle\lrcorner}}
\ProvideDocumentCommand{\setqedsymbol}{m}{ \RenewDocumentCommand{\qedsymbol}{}{#1} }
\ProvideDocumentCommand{\settheoremendsymbol}{m}{ \RenewDocumentCommand{\thmendsymb}{}{#1} }
\RenewDocumentCommand{\qedsymbol}{}{\ensuremath{\scriptstyle\square}}

\ProvideDocumentCommand{\SetQEDSymbol}{m}{ \setqedsymbol{#1} }
\ProvideDocumentCommand{\SetTheoremEndSymbol}{m}{ \settheoremendsymbol{#1} }

\declaretheoremstyle[
	headfont      = \bfseries,
	notefont      = \normalfont,
	bodyfont      = \normalfont,
	spaceabove    = 3pt,
	spacebelow    = 3pt,
	headpunct     = {.},
	postheadspace = 0.5em,
	qed           = {\thmendsymb}
]{csam@theoremlike}

\declaretheoremstyle[
	headfont      = \bfseries,
	notefont      = \normalfont,
	bodyfont      = \normalfont,
	spaceabove    = 3pt,
	spacebelow    = 3pt,
	headpunct     = {.},
	postheadspace = 0.5em,
	qed           = {\thmendsymb}
]{csam@definitionlike}

\declaretheoremstyle[
	headfont      = \normalfont\scshape,
	notefont      = \normalfont,
	bodyfont      = \normalfont,
	spaceabove    = 3pt,
	spacebelow    = 3pt,
	headpunct     = {.},
	postheadspace = 0.5em,
	qed           = {\thmendsymb}
]{csam@remarklike}

\declaretheoremstyle[
	headfont      = \normalfont\sffamily,
	notefont      = \normalfont,
	bodyfont      = \normalfont,
	spaceabove    = 3pt,
	spacebelow    = 3pt,
	headpunct     = {.},
	postheadspace = 0.5em,
	qed           = {\thmendsymb}
]{csam@highlightlike}

\declaretheorem
[
	name         = Theorem ,
	style        = csam@theoremlike ,
	numberwithin = section
]{theorem}

\NewDocumentCommand{\csam@declaretheoremfamily}{m m}{%
	\forcsvlist{\declaretheorem[sibling=theorem,style=#1]}{#2}%
}

\csam@declaretheoremfamily{csam@theoremlike}{
	assertion,%
	assumption,%
	axiom,%
	claim,%
	conclusion,%
	conjecture,%
	corollary,%
	criterion,%
	fact,%
	folklore,%
	hypothesis,%
	lemma,%
	observation,%
	postulate,%
	property,%
	proposition
}

\declaretheorem
[
	name    = {Informal~Theorem} ,
	sibling = theorem ,
	style   = csam@theoremlike
]{informaltheorem}
\declaretheorem
[
	name    = {Meta~Theorem} ,
	sibling = theorem ,
	style   = csam@theoremlike
]{metatheorem}

\csam@declaretheoremfamily{csam@definitionlike}{
	application,%
	construction,%
	convention,%
	definition,%
	example,%
	experiment,%
	notation,%
	problem,%
	protocol,%
	result,%
	solution,%
	step
}

\csam@declaretheoremfamily{csam@remarklike}{
	commentary,%
	discussion,%
	exercise,%
	motivation,%
	note,%
	question,%
	remark,%
	syntax
}

\declaretheorem
[
	name    = {Notation~Abuse} ,
	sibling = theorem ,
	style   = csam@remarklike
]{notationabuse}
\declaretheorem
[
	name    = {Open~Problem} ,
	sibling = theorem ,
	style   = csam@remarklike
]{openproblem}

\csam@declaretheoremfamily{csam@highlightlike}{
	guideline,% 
	highlight,% 
	important,% 
	insight,% 
	recall,% 
	summary,% 
	takeaway,% 
	tip,% 
	warning
}

\declaretheorem
[
	name    = {Key~Point} ,
	sibling = theorem ,
	style   = csam@highlightlike
]{keypoint}

\declaretheorem[ name = Claim ,                 style = csam@theoremlike , numbered = no ]{claim*}
\declaretheorem[ name = Conjecture ,            style = csam@theoremlike , numbered = no ]{conjecture*}
\declaretheorem[ name = Corollary ,             style = csam@theoremlike , numbered = no ]{corollary*}
\declaretheorem[ name = Hypothesis ,            style = csam@theoremlike , numbered = no ]{hypothesis*}
\declaretheorem[ name = Lemma ,                 style = csam@theoremlike , numbered = no ]{lemma*}
\declaretheorem[ name = Syntax ,                style = csam@remarklike  , numbered = no ]{syntax*}
\declaretheorem[ name = Theorem ,               style = csam@theoremlike , numbered = no ]{theorem*}
\declaretheorem[ name = {Informal~Theorem} ,    style = csam@theoremlike , numbered = no ]{informaltheorem*}
\declaretheorem[ name = {Open~Problem} ,        style = csam@remarklike  , numbered = no ]{openproblem*}

\NewDocumentEnvironment{proofsketch}{o}
{
	\IfNoValueTF{#1}
	{ \begin{proof}[Proof~(Sketch)] }
	{ \begin{proof}[Proof~(Sketch~#1)] }
}
{ \end{proof} }

\NewDocumentEnvironment{proofidea}{o}
{
