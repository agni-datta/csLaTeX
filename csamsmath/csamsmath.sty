%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Options
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\tl_new:N  \g_csam_font_tl
\bool_new:N \g_csam_draft_bool

\tl_gset:Nn \g_csam_font_tl { latinmodern }

\keys_define:nn { csamsmath }
{
	font         .tl_gset:N   = \g_csam_font_tl ,
	font         .initial:n   = latinmodern ,
	baskervaldx  .code:n      = { \tl_gset:Nn \g_csam_font_tl { baskervaldx } } ,
	concrete     .code:n      = { \tl_gset:Nn \g_csam_font_tl { concrete    } } ,
	garamond     .code:n      = { \tl_gset:Nn \g_csam_font_tl { garamond    } } ,
	gfsdidot     .code:n      = { \tl_gset:Nn \g_csam_font_tl { gfsdidot    } } ,
	kpfonts      .code:n      = { \tl_gset:Nn \g_csam_font_tl { kpfonts     } } ,
	latinmodern  .code:n      = { \tl_gset:Nn \g_csam_font_tl { latinmodern } } ,
	libertine    .code:n      = { \tl_gset:Nn \g_csam_font_tl { libertine   } } ,
	palatino     .code:n      = { \tl_gset:Nn \g_csam_font_tl { palatino    } } ,
	draft        .bool_gset:N = \g_csam_draft_bool ,
	draft        .initial:n   = false ,
	final        .code:n      = { \bool_gset_false:N \g_csam_draft_bool } ,
	unknown      .code:n      = { \PackageWarning{csamsmath}{Unknown~option~`#1'~ignored} } ,
}
\ProcessKeysOptions { csamsmath }
\tl_if_blank:VT \g_csam_font_tl
{
	\tl_gset:Nn \g_csam_font_tl { latinmodern }
}

\newif\ifcsam@baskervaldx  \tl_if_eq:NnT \g_csam_font_tl { baskervaldx } { \csam@baskervaldxtrue }
\newif\ifcsam@concrete     \tl_if_eq:NnT \g_csam_font_tl { concrete    } { \csam@concretetrue    }
\newif\ifcsam@garamond     \tl_if_eq:NnT \g_csam_font_tl { garamond    } { \csam@garamondtrue    }
\newif\ifcsam@gfsdidot     \tl_if_eq:NnT \g_csam_font_tl { gfsdidot    } { \csam@gfsdidottrue    }
\newif\ifcsam@kpfonts      \tl_if_eq:NnT \g_csam_font_tl { kpfonts     } { \csam@kpfontstrue     }
\newif\ifcsam@latinmodern  \tl_if_eq:NnT \g_csam_font_tl { latinmodern } { \csam@latinmoderntrue }
\newif\ifcsam@libertine    \tl_if_eq:NnT \g_csam_font_tl { libertine   } { \csam@libertinetrue   }
\newif\ifcsam@palatino     \tl_if_eq:NnT \g_csam_font_tl { palatino    } { \csam@palatinotrue    }
\newif\ifcsam@draft        \bool_if:NTF \g_csam_draft_bool { \csam@drafttrue }{ \csam@draftfalse }

\ExplSyntaxOff

