\RequirePackage{marginnote}

\providecommand{\csam@colorize}{\color{Firebrick2}}

\newcommand{\csam@brokenrefmark}[1]{%
    \marginnote[
        {\csam@colorize\normalfont\smash{\LARGE$\star$}\,\tiny\sffamily#1}
    ]{
        {\csam@colorize\normalfont\smash{\LARGE$\star$}\,\tiny\sffamily#1}
    }%
}

\newif\ifcsam@markundef
\csam@markundeftrue

\xpretocmd{\G@refundefinedtrue}{%
    \ifcsam@markundef
        \csam@brokenrefmark{\@ifundefined{@citeb}{}{\@citeb}}%
    \fi
}{}{}

\let\csam@old@setref\@setref
\renewcommand{\@setref}[3]{%
    \ifx#1\relax\csam@brokenrefmark{#3}\fi
    \csam@markundeffalse
    \csam@old@setref{#1}{#2}{#3}%
    \csam@markundeftrue
}

\NewDocumentCommand{\newguymarker}{m m m}{%
    \ifcsam@draft
        \expandafter\newcommand\csname #1\endcsname[1]{%
            \textcolor{#3}{##1\ \textsc{#2}}%
            \marginnote{\textcolor{#3}{\LARGE$\star$}}%
        }%
    \else
        \expandafter\newcommand\csname #1\endcsname[1]{}%
    \fi
}

\ifcsam@draft
    \NewDocumentCommand{\added}{m}{%
        \textcolor{OliveGreen}{#1}\marginnote{\textcolor{OliveGreen}{\LARGE$\star$}}}
    \NewDocumentCommand{\changed}{m}{%
        \textcolor{PineGreen}{#1}\marginnote{\textcolor{PineGreen}{\LARGE$\star$}}}
    \NewDocumentCommand{\citelater}{m}{%
        \textcolor{WildStrawberry}{[#1]}\marginnote{\textcolor{WildStrawberry}{\LARGE$\star$}}}
    \NewDocumentCommand{\fixme}{m}{%
        \textcolor{OrangeRed}{[\textsc{Fix-me}: #1]}\marginnote{\textcolor{OrangeRed}{\LARGE$\star$}}}
    \NewDocumentCommand{\missing}{m}{%
        \textcolor{Crimson}{#1}\marginnote{\textcolor{Crimson}{\LARGE$\star$}}}
    \NewDocumentCommand{\notes}{m}{%
        \textcolor{ForestGreen}{[\textsc{Note}: #1]}\marginnote{\textcolor{ForestGreen}{\LARGE$\star$}}}
    \NewDocumentCommand{\query}{m}{%
        \textcolor{RoyalPurple}{[\textsc{Query}: #1]}\marginnote{\textcolor{RoyalPurple}{\LARGE$\star$}}}
    \NewDocumentCommand{\removed}{m}{%
        \textcolor{Periwinkle}{\sout{#1}}\marginnote{\textcolor{Periwinkle}{\LARGE$\star$}}}
    \NewDocumentCommand{\todo}{m}{%
        \textcolor{Mahogany}{[\textsc{To-do}: #1]}\marginnote{\textcolor{Mahogany}{\LARGE$\star$}}}
    \NewDocumentCommand{\XXX}{o}{%
        \marginnote{{\color{PaleVioletRed3}\normalfont$\star$}}%
        \textcolor{PaleVioletRed3}{\sffamily
            \IfNoValueTF{#1}
            {[XXX]}
            {[#1]}%
        }%
    }
    \IfFileExists{scrtime.sty}{%
        \RequirePackage{scrtime}%
        \RequirePackage{prelim2e}%
        \newcommand\csam@datetime{%
            \the\year-\ifnum\the\month<10 0\fi\the\month-%
            \ifnum\the\day<10 0\fi\the\day\space\thistime}%
        \renewcommand\PrelimText{%
            \normalfont\scshape\footnotesize\color{DeepPink3}%
            Draft --- {\csam@datetime} --- Not for Distribution}%
    }{}%
\else
    \NewDocumentCommand{\added}{m}{}
    \NewDocumentCommand{\changed}{m}{}
    \NewDocumentCommand{\citelater}{m}{}
    \NewDocumentCommand{\fixme}{m}{}
    \NewDocumentCommand{\missing}{m}{}
    \NewDocumentCommand{\notes}{m}{}
    \NewDocumentCommand{\query}{m}{}
    \NewDocumentCommand{\removed}{m}{}
    \NewDocumentCommand{\todo}{m}{}
    \NewDocumentCommand{\XXX}{O{XXX}}{%
        \@latex@error{\string\XXX{} found in final mode — remove all \string\XXX before submission}\@ehd
    }
\fi

