\newcommand\csam@setcrefnames[1]{%
    \forcsvlist{\csam@setcrefname@single}{#1}%
}
\def\csam@setcrefname@single#1{%
    \csam@setcrefname@parse#1\csam@nil
}
\def\csam@setcrefname@parse#1/#2/#3\csam@nil{%
    \crefname{#1}{#2}{#3}%
}

