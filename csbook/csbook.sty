%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Sectioning
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{titlesec}

\def\@partfont        {\normalfont\raggedleft}
\def\@partlabelfont   {\huge\scshape}
\def\@chapterfont     {\huge\sffamily\raggedleft}
\def\@chapterlabelfont{\normalfont\scshape}
\def\@sectionfont     {\large\centering\scshape}
\def\@sectionnumfont  {\normalfont}
\def\@subsectionfont  {\normalfont\normalsize\scshape\centering}
\def\@subsubsectionfont{\normalfont\normalsize\scshape}

\NewDocumentCommand{\partfont}         {m}{\def\@partfont{#1}}
\NewDocumentCommand{\partlabelfont}    {m}{\def\@partlabelfont{#1}}
\NewDocumentCommand{\chapterfont}      {m}{\def\@chapterfont{#1}}
\NewDocumentCommand{\chapterlabelfont} {m}{\def\@chapterlabelfont{#1}}
\NewDocumentCommand{\sectionfont}      {m}{\def\@sectionfont{#1}}
\NewDocumentCommand{\sectionnumfont}   {m}{\def\@sectionnumfont{#1}}
\NewDocumentCommand{\subsectionfont}   {m}{\def\@subsectionfont{#1}}
\NewDocumentCommand{\subsubsectionfont}{m}{\def\@subsubsectionfont{#1}}

\titleformat{\part}[display]
{\@partfont}
{\@partlabelfont\partname\enspace\thepart}
{8pt}
{\titlerule[1pt]\bigskip\Huge}
[{\bigskip\titlerule[1pt]}]

\titlespacing*{\part}{0pt}{\fill}{\fill}

\titleformat{\chapter}[display]
{\filcenter}
{\raggedleft\@chapterlabelfont{\enspace\chaptername}\enspace{\Huge\thechapter}\medskip}
{0.3ex}
{\titlerule[1pt]\vskip2.5ex\@chapterfont}
[{\medskip\titlerule[1pt]}]

\titleformat{\section}[block]
{\@sectionfont}
{}
{1em}
{{\@sectionnumfont\textsection\;\thesection}\enspace}
[]

\titleformat{\subsection}[runin]
{\@subsectionfont}
{\textsection\textsection\;\thesubsection}
{1em}
{}[.]

\titleformat{\subsubsection}[runin]
{\@subsubsectionfont}
{\thesubsubsection.}
{1em}
{}[.]

\titlespacing*{\subsubsection}{0pt}{1em}{1em}

