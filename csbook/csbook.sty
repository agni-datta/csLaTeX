\etocsetstyle{part}
{\addvspace{2.618\baselineskip}\etocskipfirstprefix}
{\addvspace{0.382\baselineskip}}
{
	\vskip0.618\baselineskip
	\titlerule
	\vskip0.382\baselineskip
	\noindent\normalsize\scshape\etocnumber\enspace\etocname\par
	\vskip0.382\baselineskip
	\titlerule
	\addvspace{0.618\baselineskip}
}
{}

\etocsetstyle{chapter}
{}
{\addvspace{0.382\baselineskip}}
{
	\noindent\normalsize\normalfont
	\makebox[2em][l]{\etocnumber}
	\scshape\etocname\nobreak
	\leaders\hbox{$\m@th\mkern 4.5mu.\mkern 4.5mu$}\hfill
	\nobreak
	\makebox[1.5em][r]{\normalfont\small\etocpage}
	\par
}
{}

\etocsetstyle{section}
{}
{}
{
	\noindent\small\normalfont\hspace{2.15em}
	\makebox[2em][l]{\etocnumber}
	\etocname\nobreak
	\leaders\hbox{$\m@th\mkern 4.5mu.\mkern 4.5mu$}\hfill
	\nobreak
	\makebox[1.5em][r]{\etocpage}
	\par
}
{}

\etocsetstyle{subsection}{}{}{}{}

\etocsettocstyle
{\chapter*{\contentsname}\addvspace{1.618\baselineskip}}
{}

