%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Broken-reference markers
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{marginnote}

\ProvideDocumentCommand{\csbk@colorize}{}{\color{Firebrick2}}

\NewDocumentCommand{\csbk@brokenrefmark}{m}{%
	\marginnote[
		{\csbk@colorize\normalfont\smash{\LARGE$\star$}\,\tiny\sffamily#1}
	]{
		{\csbk@colorize\normalfont\smash{\LARGE$\star$}\,\tiny\sffamily#1}
	}%
}

\newif\ifcsbk@markundef
\csbk@markundeftrue

\xpretocmd{\G@refundefinedtrue}{%
	\ifcsbk@markundef
		\csbk@brokenrefmark{\@ifundefined{@citeb}{}{\@citeb}}%
	\fi
}{}{}

\let\csbk@old@setref\@setref
\RenewDocumentCommand{\@setref}{m m m}{%
	\ifx#1\relax\csbk@brokenrefmark{#3}\fi
	\csbk@markundeffalse
	\csbk@old@setref{#1}{#2}{#3}%
	\csbk@markundeftrue
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Draft annotations
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\NewDocumentCommand{\newguymarker}{m m m}{%
	\ifcsbk@draft
		\expandafter\NewDocumentCommand\csname #1\endcsname{m}{%
			\textcolor{#3}{##1\ \textsc{#2}}%
			\marginnote{\textcolor{#3}{\LARGE$\star$}}%
		}%
	\else
		\expandafter\NewDocumentCommand\csname #1\endcsname{m}{}%
	\fi
}

\ifcsbk@draft
	\NewDocumentCommand{\added}   {m}{\textcolor{OliveGreen}{#1}\marginnote{\textcolor{OliveGreen}{\LARGE$\star$}}}
	\NewDocumentCommand{\changed} {m}{\textcolor{PineGreen}{#1}\marginnote{\textcolor{PineGreen}{\LARGE$\star$}}}
	\NewDocumentCommand{\citelater}{m}{\textcolor{WildStrawberry}{[#1]}\marginnote{\textcolor{WildStrawberry}{\LARGE$\star$}}}
	\NewDocumentCommand{\fixme}   {m}{\textcolor{OrangeRed}{[\textsc{Fix-me}: #1]}\marginnote{\textcolor{OrangeRed}{\LARGE$\star$}}}
	\NewDocumentCommand{\missing} {m}{\textcolor{Crimson}{#1}\marginnote{\textcolor{Crimson}{\LARGE$\star$}}}
	\NewDocumentCommand{\notes}   {m}{\textcolor{ForestGreen}{[\textsc{Note}: #1]}\marginnote{\textcolor{ForestGreen}{\LARGE$\star$}}}
	\NewDocumentCommand{\query}   {m}{\textcolor{RoyalPurple}{[\textsc{Query}: #1]}\marginnote{\textcolor{RoyalPurple}{\LARGE$\star$}}}
	\NewDocumentCommand{\removed} {m}{\textcolor{Periwinkle}{\sout{#1}}\marginnote{\textcolor{Periwinkle}{\LARGE$\star$}}}
	\NewDocumentCommand{\todo}    {m}{\textcolor{Mahogany}{[\textsc{To-do}: #1]}\marginnote{\textcolor{Mahogany}{\LARGE$\star$}}}
	\IfFileExists{scrtime.sty}{%
		\RequirePackage{scrtime}%
		\RequirePackage{prelim2e}%
		\NewDocumentCommand{\csbk@datetime}{}{%
			\the\year-\ifnum\the\month<10 0\fi\the\month-%
			\ifnum\the\day<10 0\fi\the\day\space\thistime%
		}%
		\RenewDocumentCommand{\PrelimText}{}{%
			\normalfont\scshape\footnotesize\color{DeepPink3}%
			Draft --- {\csbk@datetime} --- Not for Distribution.%
		}%
	}{}%
\else
	\NewDocumentCommand{\added}   {m}{}
	\NewDocumentCommand{\changed} {m}{}
	\NewDocumentCommand{\citelater}{m}{}
	\NewDocumentCommand{\fixme}   {m}{}
	\NewDocumentCommand{\missing} {m}{}
	\NewDocumentCommand{\notes}   {m}{}
	\NewDocumentCommand{\query}   {m}{}
	\NewDocumentCommand{\removed} {m}{}
	\NewDocumentCommand{\todo}    {m}{}
\fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Title and authors
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{titling}
\RequirePackage[auth-sc]{authblk}

\def\@institute{}
\def\@subtitle{}
\NewDocumentCommand{\institute}{m}{\def\@institute{#1}}
\NewDocumentCommand{\subtitle} {m}{\def\@subtitle{#1}}

\def\@authorfont   {\normalsize\scshape}
\def\@institutefont{\small\normalfont}
\def\@datefont     {\normalfont}
\def\@subtitlefont {\normalfont}
\def\@titlefont    {\normalfont}
\NewDocumentCommand{\authorfont}   {m}{\def\@authorfont{#1}}
\NewDocumentCommand{\institutefont}{m}{\def\@institutefont{#1}}
\NewDocumentCommand{\datefont}     {m}{\def\@datefont{#1}}
\NewDocumentCommand{\subtitlefont} {m}{\def\@subtitlefont{#1}}
\NewDocumentCommand{\titlefont}    {m}{\def\@titlefont{#1}}

\newlength{\goldenunit}
\setlength{\goldenunit}{1cm}

\RenewDocumentCommand{\maketitlehooka}{}{%
	\thispagestyle{empty}%
	\null\vskip 0.12\textheight\relax
	\begin{flushleft}%
	\rule{\textwidth}{1pt}\par
	\vspace{0.618\goldenunit}%
}
\RenewDocumentCommand{\maketitlehookd}{}{%
	\end{flushleft}%
	\cleardoublepage
}

\pretitle{\fontsize{52}{56}\selectfont\@titlefont}
\posttitle{%
	\par\vspace{-\goldenunit}%
	\rule{\textwidth}{1pt}\par
	\ifx\@subtitle\@empty
		\vspace{1.618\goldenunit}%
	\else
		\vspace{\goldenunit}%
		{\large\@subtitlefont$\diamond$\enspace\@subtitle\enspace$\diamond$\par}%
		\vspace{1.618\goldenunit}%
	\fi
}

\preauthor{\large\@authorfont}
\postauthor{\par\vfill}

\predate{\rule{\textwidth}{1pt}\par\vspace{0.618\goldenunit}\large\@datefont}
\postdate{\par}

\RenewDocumentCommand{\Authfont}{}{\@authorfont}
\RenewDocumentCommand{\Affilfont}{}{\@institutefont}

\makeatother
\endinput
