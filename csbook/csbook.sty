\newif\ifcsbk@mathalpha@stylish

\ifLuaTeX

	\RequirePackage{fontspec}
	\RequirePackage{lmodern}
	\RequirePackage{sansmath}
	\RequirePackage[warnings-off={mathtools-colon,mathtools-overbracket,no-alphabet}]{unicode-math}

	\NewDocumentCommand{\csbk@luamono}{}{%
		\setmonofont{Inconsolata}[
			Scale      = MatchLowercase,
			Ligatures  = TeX,
			RawFeature = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		]%
	}
	\NewDocumentCommand{\csbk@luasans}{O{MatchUppercase}}{%
		\setsansfont{Libertinus Sans}[
			Scale             = #1,
			Ligatures         = TeX,
			SmallCapsFeatures = {RawFeature=+smcp},
			RawFeature        = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		]%
	}
	\NewDocumentCommand{\csbk@luamathsf}{}{%
		\setmathfont{Libertinus Sans}[
			Scale      = MatchUppercase,
			range      = {sfup/{latin,Latin,num},sfit/{latin,Latin}},
			Ligatures  = TeX,
			RawFeature = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		]%
	}
	\NewDocumentCommand{\csbk@luamathtt}{}{%
		\setmathfont{Inconsolata}[
			Scale      = MatchUppercase,
			range      = {tt/{latin,Latin,num}},
			RawFeature = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		]%
	}

	\ifcsbk@baskervaldx
		\setmainfont{Baskervaldx}[
			Ligatures         = TeX,
			SmallCapsFeatures = {RawFeature=+smcp},
			RawFeature        = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		]
		\csbk@luasans
		\csbk@luamono
		\setmathfont{KPMath-Regular}[
			AutoFakeBold, AutoFakeSlant,
			Scale      = MatchUppercase,
			RawFeature = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		]
		\setmathfont{Baskervaldx-Reg}[
			Scale      = MatchUppercase,
			range      = {up/{latin,Latin,num}},
			Ligatures  = TeX,
			RawFeature = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		]
		\setmathfont{Baskervaldx-Ita}[
			Scale      = MatchUppercase,
			range      = {it/{latin,Latin}},
			Ligatures  = TeX,
			RawFeature = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		]
		\csbk@luamathsf
		\csbk@luamathtt
		\csbk@mathalpha@stylishtrue
	\fi

	\ifcsbk@concrete
		\RequirePackage[euler]{fontsetup}
		\defaultfontfeatures{
			SmallCapsFeatures = {RawFeature=+smcp,+lnum,+tnum},
			RawFeature        = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		}
		\csbk@mathalpha@stylishfalse
	\fi

	\ifcsbk@garamond
		\setmainfont{GaramondLibre-Regular}[
			Ligatures         = TeX,
			BoldFont          = GaramondLibre-Bold.otf,
			BoldItalicFont    = GaramondLibre-BoldItalic.otf,
			ItalicFont        = GaramondLibre-Italic.otf,
			SmallCapsFont     = EBGaramond-Regular.otf,
			SmallCapsFeatures = {RawFeature={+smcp,+lnum,+tnum}},
			RawFeature        = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		]
		\csbk@luasans[MatchLowercase]
		\csbk@luamono
		\setmathfont{Garamond Math}[
			AutoFakeBold, AutoFakeSlant,
			Scale      = MatchUppercase,
			RawFeature = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		]
		\setmathfont{GaramondLibre-Regular}[
			Scale      = MatchUppercase,
			range      = {up/{latin,Latin,num}},
			Ligatures  = TeX,
			RawFeature = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		]
		\setmathfont{GaramondLibre-Italic}[
			Scale      = MatchUppercase,
			range      = {it/{latin,Latin}},
			Ligatures  = TeX,
			RawFeature = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		]
		\csbk@luamathsf
		\csbk@luamathtt
		\csbk@mathalpha@stylishtrue
	\fi

	\ifcsbk@gfsdidot
		\RequirePackage[gfsdidot]{fontsetup}
		\csbk@luasans
		\csbk@luamono
		\csbk@mathalpha@stylishtrue
	\fi

	\ifcsbk@kpfonts
		\RequirePackage[nosf,noDcommand,fakedscripts]{kpfonts-otf}
		\csbk@luasans
		\csbk@luamono
		\csbk@mathalpha@stylishtrue
	\fi

	\ifcsbk@latinmodern
		\setmainfont{Latin Modern Roman}[
			Ligatures         = TeX,
			SmallCapsFont     = Latin Modern Roman Caps,
			SmallCapsFeatures = {RawFeature=+smcp},
			RawFeature        = {+calt,+case,+kern,+mark,+mkmk,+liga,+lnum,+tnum}
		]
		\setsansfont{Latin Modern Sans}[
			Scale             = MatchUppercase,
			Ligatures         = TeX,
			SmallCapsFeatures = {Letters=SmallCaps},
			RawFeature        = {+calt,+case,+kern,+mark,+mkmk,+liga,+lnum,+tnum}
		]
		\setmonofont{Latin Modern Mono}[
			Scale      = MatchLowercase,
			Ligatures  = TeX,
			RawFeature = {+calt,+case,+kern,+mark,+mkmk,+liga,+lnum,+tnum}
		]
		\setmathfont{Latin Modern Math}[
			AutoFakeBold, AutoFakeSlant,
			RawFeature = {+calt,+case,+kern,+mark,+mkmk,+liga,+lnum,+tnum}
		]
		\csbk@mathalpha@stylishfalse
	\fi

	\ifcsbk@libertine
		\setmainfont{Libertinus Serif}[
			Ligatures         = TeX,
			SmallCapsFeatures = {RawFeature=+smcp},
			RawFeature        = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		]
		\csbk@luasans
		\csbk@luamono
		\setmathfont{Libertinus Math}[
			AutoFakeBold, AutoFakeSlant,
			Scale      = MatchUppercase,
			RawFeature = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		]
		\csbk@mathalpha@stylishtrue
	\fi

	\ifcsbk@palatino
		\setmainfont{TeX Gyre Pagella}[
			Ligatures  = TeX,
			RawFeature = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		]
		\csbk@luasans
		\csbk@luamono
		\setmathfont{TeX Gyre Pagella Math}[
			AutoFakeBold, AutoFakeSlant,
			RawFeature = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
		]
		\csbk@mathalpha@stylishtrue
	\fi

\else

	\RequirePackage{sansmath}

	\NewDocumentCommand{\csbk@pdfmono}{}{\RequirePackage{inconsolata}}
	\NewDocumentCommand{\csbk@pdfsans}{}{\RequirePackage{biolinum}}

	\ifcsbk@baskervaldx
		\RequirePackage[proportional,tabular]{Baskervaldx}
		\csbk@pdfsans
		\csbk@pdfmono
		\RequirePackage[baskervaldx,varbb]{newtxmath}
		\csbk@mathalpha@stylishtrue
	\fi

	\ifcsbk@concrete
		\RequirePackage{ccfonts}
		\RequirePackage{concmath}
		\csbk@mathalpha@stylishfalse
	\fi

	\ifcsbk@garamond
		\RequirePackage[proportional,tabular]{garamondlibre}
		\csbk@pdfsans
		\csbk@pdfmono
		\RequirePackage[ebgaramond,varbb]{newtxmath}
		\csbk@mathalpha@stylishtrue
	\fi

	\ifcsbk@gfsdidot
		\csbk@pdfsans
		\csbk@pdfmono
		\RequirePackage{gfsdidot}
		\RequirePackage[libertine,varbb]{newtxmath}
		\RenewDocumentCommand{\sfdefault}{}{LinuxBiolinumT-TLF}
		\csbk@mathalpha@stylishtrue
	\fi

	\ifcsbk@kpfonts
		\csbk@pdfsans
		\csbk@pdfmono
		\RequirePackage[tabular]{libertineRoman}
		\RequirePackage[libertine,varbb]{newtxmath}
		\csbk@mathalpha@stylishtrue
		\PackageWarning{csbook}{kpfonts: use LuaLaTeX instead of pdfLaTeX.}
	\fi

	\ifcsbk@latinmodern
		\RequirePackage{lmodern}
		\csbk@mathalpha@stylishfalse
	\fi

	\ifcsbk@libertine
		\csbk@pdfsans
		\csbk@pdfmono
		\RequirePackage[tabular]{libertineRoman}
		\RequirePackage[libertine,varbb]{newtxmath}
		\csbk@mathalpha@stylishtrue
	\fi

	\ifcsbk@palatino
		\csbk@pdfsans
		\csbk@pdfmono
		\RequirePackage{tgpagella}
		\RequirePackage[sc]{mathpazo}
		\csbk@mathalpha@stylishtrue
	\fi

\fi

