\newif\ifcsbk@haspunctuation

\def\csbk@checkpunctuation#1{%
    \ifx\csbk@checkpunctuation#1\csbk@checkpunctuation
    \else
        \csbk@haspunctuationtrue
    \fi
}

\def\csbk@checkdot#1.\csbk@delim#2\csbk@stop{\csbk@checkpunctuation{#2}}
\def\csbk@checkquestion#1?\csbk@delim#2\csbk@stop{\csbk@checkpunctuation{#2}}
\def\csbk@checkexclam#1!\csbk@delim#2\csbk@stop{\csbk@checkpunctuation{#2}}
\def\csbk@checkcolon#1:\csbk@delim#2\csbk@stop{\csbk@checkpunctuation{#2}}

\def\csbk@appendpunctuationifneeded#1{%
    \csbk@haspunctuationfalse
    \csbk@checkdot#1\csbk@delim.\csbk@delim\csbk@stop
    \csbk@checkquestion#1\csbk@delim?\csbk@delim\csbk@stop
    \csbk@checkexclam#1\csbk@delim!\csbk@delim\csbk@stop
    \csbk@checkcolon#1\csbk@delim:\csbk@delim\csbk@stop
    #1\ifcsbk@haspunctuation \else.\fi%
}

\def\csbk@ignorewhitespaceandimplicitpars{%
    \begingroup
    \catcode13=10 %
    \@ifnextchar\relax
    {\endgroup}
    {\endgroup}%
}

\NewDocumentCommand{\csbk@paragraphhead}{m}{%
    \smallskip
    \noindent
    \textbf{\boldmath\ignorespaces\csbk@appendpunctuationifneeded{#1}}%
    \hskip 0.9em plus 0.3em minus 0.3em
    \csbk@ignorewhitespaceandimplicitpars
}

\NewDocumentCommand{\csbk@subparagraphhead}{m}{%
    \smallskip
    \noindent
    \textsc{\ignorespaces\csbk@appendpunctuationifneeded{#1}}%
    \hskip 0.9em plus 0.3em minus 0.3em
    \csbk@ignorewhitespaceandimplicitpars
}

\NewDocumentCommand{\parhead}{m}{\csbk@paragraphhead{#1}}
\NewDocumentCommand{\subparhead}{m}{\csbk@subparagraphhead{#1}}

\AtBeginDocument{%
    \RenewDocumentCommand{\Pr}{}{\mathop{\mathsf{Pr}}}%
    \RenewDocumentCommand{\paragraph}{m}{\parhead{#1}}%
    \RenewDocumentCommand{\subparagraph}{m}{\subparhead{#1}}%
}

\RequirePackage{marginnote}

\providecommand{\csbk@colorize}{\color{Firebrick2}}

\newcommand{\csbk@brokenrefmark}[1]{
    \marginnote[
        {\csbk@colorize\normalfont\smash{\LARGE$\star$}\,\tiny\sffamily#1}
    ]{
        {\csbk@colorize\normalfont\smash{\LARGE$\star$}\,\tiny\sffamily#1}
    }
}

\newbool{csbk@markundef}
\booltrue{csbk@markundef}

\xpretocmd{\G@refundefinedtrue}{
    \ifbool{csbk@markundef}{
        \csbk@brokenrefmark{\@ifundefined{@citeb}{}{\@citeb}}
    }{}
}{}{}

\let\csbk@old@setref\@setref
\renewcommand{\@setref}[3]{
    \ifx#1\relax\csbk@brokenrefmark{#3}\fi
    \csbk@markundeffalse
    \csbk@old@setref{#1}{#2}{#3}
    \csbk@markundeftrue
}

\NewDocumentCommand{\newguymarker}{m m m}{
    \ifcsbk@draft
        \expandafter\newcommand\csname #1\endcsname[1]{
            \textcolor{#3}{##1\ \textsc{#2}}
            \marginnote{\textcolor{#3}{\LARGE$\star$}}
        }
    \else
        \expandafter\newcommand\csname #1\endcsname[1]{}
    \fi
}

\ifcsbk@draft
    \NewDocumentCommand{\added}{m}{
        \textcolor{OliveGreen}{#1}\marginnote{\textcolor{OliveGreen}{\LARGE$\star$}}
    }
    \NewDocumentCommand{\changed}{m}{
        \textcolor{PineGreen}{#1}\marginnote{\textcolor{PineGreen}{\LARGE$\star$}}
    }
    \NewDocumentCommand{\citelater}{m}{
        \textcolor{WildStrawberry}{[#1]}\marginnote{\textcolor{WildStrawberry}{\LARGE$\star$}}
    }
    \NewDocumentCommand{\fixme}{m}{
        \textcolor{OrangeRed}{[\textsc{Fix-me}: #1]}\marginnote{\textcolor{OrangeRed}{\LARGE$\star$}}
    }
    \NewDocumentCommand{\missing}{m}{
        \textcolor{Crimson}{#1}\marginnote{\textcolor{Crimson}{\LARGE$\star$}}
    }
    \NewDocumentCommand{\notes}{m}{
        \textcolor{ForestGreen}{[\textsc{Note}: #1]}\marginnote{\textcolor{ForestGreen}{\LARGE$\star$}}
    }
    \NewDocumentCommand{\query}{m}{
        \textcolor{RoyalPurple}{[\textsc{Query}: #1]}\marginnote{\textcolor{RoyalPurple}{\LARGE$\star$}}
    }
    \NewDocumentCommand{\removed}{m}{
        \textcolor{Periwinkle}{\sout{#1}}\marginnote{\textcolor{Periwinkle}{\LARGE$\star$}}
    }
    \NewDocumentCommand{\todo}{m}{
        \textcolor{Mahogany}{[\textsc{To-do}: #1]}\marginnote{\textcolor{Mahogany}{\LARGE$\star$}}
    }
\else
    \NewDocumentCommand{\added}{m}{}
    \NewDocumentCommand{\changed}{m}{}
    \NewDocumentCommand{\citelater}{m}{}
    \NewDocumentCommand{\fixme}{m}{}
    \NewDocumentCommand{\missing}{m}{}
    \NewDocumentCommand{\notes}{m}{}
    \NewDocumentCommand{\query}{m}{}
    \NewDocumentCommand{\removed}{m}{}
    \NewDocumentCommand{\todo}{m}{}
\fi

