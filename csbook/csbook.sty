\long\def\csbk@CustomFBox#1#2#3#4#5#6#7#8#9{%
	\leavevmode\begingroup
	\setbox\@tempboxa\hbox{\color@begingroup\kern\fboxsep{#9}\kern\fboxsep\color@endgroup}%
	\hbox{\begingroup\@tempdima#4\relax
		\advance\@tempdima\fboxsep\advance\@tempdima\dp\@tempboxa
		\expandafter\endgroup\expandafter
		\lower\the\@tempdima\hbox{\vbox{%
				\hrule\@height#3\@width#7\relax#1%
				\hbox{\vrule\@width#5\relax\hspace{#8}%
					\vbox{\vskip\fboxsep\copy\@tempboxa\vskip\fboxsep}%
					\vrule\@width#6\relax}%
				#2\hrule\@height#4\@width#7\relax}}}%
	\endgroup
}

\def\csbk@OpenFBox#1#2{%
	\fboxsep\FrameSep
	\csbk@CustomFBox{}{}{#1}{#2}\FrameRule\z@{1em}{0.4em}%
}

\NewDocumentEnvironment{nestedbar}{O{\hsize}}{%
	\@ifundefined{OuterFrameSep}{\@latex@error{nestedbar requires a recent framed.sty}\@ehd}{}%
	\def\FrameCommand     {\csbk@OpenFBox\FrameRule\FrameRule}%
	\def\FirstFrameCommand{\csbk@OpenFBox\FrameRule\z@}%
	\def\MidFrameCommand  {\csbk@OpenFBox\z@\z@}%
	\def\LastFrameCommand {\csbk@OpenFBox\z@\FrameRule}%
	\OuterFrameSep=1ex\FrameSep=0pt
	\MakeFramed{\hsize#1\advance\hsize-\width\FrameRestore}\smallskip
}{%
	\smallskip\endMakeFramed
}

