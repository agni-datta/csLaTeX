\let\csw@old@setref\@setref
\renewcommand{\@setref}[3]{
    \ifx#1\relax\csw@brokenrefmark{#3}\fi
    \csw@markundeffalse
    \csw@old@setref{#1}{#2}{#3}
    \csw@markundeftrue
}

\newif\ifcsw@haspunctuation

\def\csw@checkpunctuation#1{%
    \ifx\csw@checkpunctuation#1\csw@checkpunctuation\else
        \csw@haspunctuationtrue
    \fi
}

\def\csw@checkdot      #1.\csw@delim#2\csw@stop{\csw@checkpunctuation{#2}}
\def\csw@checkquestion #1?\csw@delim#2\csw@stop{\csw@checkpunctuation{#2}}
\def\csw@checkexclam   #1!\csw@delim#2\csw@stop{\csw@checkpunctuation{#2}}
\def\csw@checkcolon    #1:\csw@delim#2\csw@stop{\csw@checkpunctuation{#2}}

\def\csw@appendpunctuationifneeded#1{%
    \csw@haspunctuationfalse
    \csw@checkdot      #1\csw@delim.\csw@delim\csw@stop
    \csw@checkquestion #1\csw@delim?\csw@delim\csw@stop
    \csw@checkexclam   #1\csw@delim!\csw@delim\csw@stop
    \csw@checkcolon    #1\csw@delim:\csw@delim\csw@stop
    #1\ifcsw@haspunctuation\else.\fi
}

\def\csw@ignorewhitespaceandimplicitpars{%
    \begingroup
    \catcode13=10\relax
    \@ifnextchar\relax{\endgroup}{\endgroup}%
}

\NewDocumentCommand{\csw@paragraphhead}{m}{%
    \smallskip
    \noindent
    \textbf{\ignorespaces\csw@appendpunctuationifneeded{#1}}%
    \hskip 0.9em plus 0.3em minus 0.3em
    \csw@ignorewhitespaceandimplicitpars
}

\NewDocumentCommand{\csw@subparagraphhead}{m}{%
    \smallskip
    \noindent
    \textsc{\ignorespaces\csw@appendpunctuationifneeded{#1}}%
    \hskip 0.9em plus 0.3em minus 0.3em
    \csw@ignorewhitespaceandimplicitpars
}

\NewDocumentCommand{\parhead}   {m}{\csw@paragraphhead{#1}}
\NewDocumentCommand{\subparhead}{m}{\csw@subparagraphhead{#1}}

\AtBeginDocument{%
    \renewcommand{\paragraph}[1]{\parhead{#1}}%
    \renewcommand{\subparagraph}[1]{\subparhead{#1}}%
    \renewcommand{\Pr}{\mathop{\mathsf{Pr}}}%
}

