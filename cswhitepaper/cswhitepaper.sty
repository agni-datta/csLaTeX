%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Draft annotations
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\ifcsw@draft
	\ProvideDocumentCommand{\added}{m}{\textcolor{OliveDrab4}{#1}\marginnote{\textcolor{OliveDrab4}{\LARGE$\star$}}}
	\ProvideDocumentCommand{\changed}{m}{\textcolor{RoyalBlue4}{#1}\marginnote{\textcolor{RoyalBlue4}{\LARGE$\star$}}}
	\ProvideDocumentCommand{\fixme}{m}{\textcolor{DarkOrange4}{[\textsc{Fix-me}:~#1]}\marginnote{\textcolor{DarkOrange3}{\LARGE$\star$}}}
	\ProvideDocumentCommand{\missing}{m}{\textcolor{MediumPurple3}{#1}\marginnote{\textcolor{MediumPurple3}{\LARGE$\star$}}}
	\ProvideDocumentCommand{\notes}{m}{\textcolor{SeaGreen4}{[\textsc{Note}:~#1]}\marginnote{\textcolor{SeaGreen4}{\LARGE$\star$}}}
	\ProvideDocumentCommand{\query}{m}{\textcolor{DarkOrchid4}{[\textsc{Query}:~#1]}\marginnote{\textcolor{DarkOrchid4}{\LARGE$\star$}}}
	\ProvideDocumentCommand{\removed}{m}{\textcolor{IndianRed4}{\sout{#1}}\marginnote{\textcolor{IndianRed4}{\LARGE$\star$}}}
	\ProvideDocumentCommand{\todo}{m}{\textcolor{Firebrick3}{[\textsc{To-do}:~#1]}\marginnote{\textcolor{Firebrick3}{\LARGE$\star$}}}
\else
	\ProvideDocumentCommand{\added}{m}{#1}
	\ProvideDocumentCommand{\changed}{m}{#1}
	\ProvideDocumentCommand{\fixme}{m}{}
	\ProvideDocumentCommand{\missing}{m}{}
	\ProvideDocumentCommand{\notes}{m}{}
	\ProvideDocumentCommand{\query}{m}{}
	\ProvideDocumentCommand{\removed}{m}{}
	\ProvideDocumentCommand{\todo}{m}{}
\fi

\NewDocumentCommand{\newguymarker}{mmm}{%
	\ifcsw@draft
		\expandafter\NewDocumentCommand\csname#1\endcsname{m}{%
			\textcolor{#3}{##1\ \textsc{#2}}%
			\marginnote{\textcolor{#3}{\LARGE$\star$}}%
		}%
	\else
		\expandafter\NewDocumentCommand\csname#1\endcsname{m}{}%
	\fi
}

\ProvideDocumentCommand{\csw@colorize}{}{\color{Firebrick2}}

\NewDocumentCommand{\csw@brokenrefmark}{m}{
	\marginnote[
		{\csw@colorize\normalfont\smash{\LARGE$\star$}\,\tiny\sffamily#1}
	]{
		{\csw@colorize\normalfont\smash{\LARGE$\star$}\,\tiny\sffamily#1}
	}
}

\newbool{csw@markundef}
\booltrue{csw@markundef}

\xpretocmd{\G@refundefinedtrue}{
	\ifbool{csw@markundef}{
		\csw@brokenrefmark{\@ifundefined{@citeb}{}{\@citeb}}
	}{}
}{}{}

\let\csw@old@setref\@setref
\RenewDocumentCommand{\@setref}{m m m}{
	\ifx#1\relax\csw@brokenrefmark{#3}\fi
	\boolfalse{csw@markundef}%
	\csw@old@setref{#1}{#2}{#3}%
	\booltrue{csw@markundef}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Paragraph headings
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\newif\ifcsw@haspunctuation

\def\csw@checkpunctuation#1{%
	\ifx\csw@checkpunctuation#1\csw@checkpunctuation\else
		\csw@haspunctuationtrue
	\fi
}

\def\csw@checkdot      #1.\csw@delim#2\csw@stop{\csw@checkpunctuation{#2}}
\def\csw@checkquestion #1?\csw@delim#2\csw@stop{\csw@checkpunctuation{#2}}
\def\csw@checkexclam   #1!\csw@delim#2\csw@stop{\csw@checkpunctuation{#2}}
\def\csw@checkcolon    #1:\csw@delim#2\csw@stop{\csw@checkpunctuation{#2}}

\def\csw@appendpunctuationifneeded#1{%
	\csw@haspunctuationfalse
	\csw@checkdot      #1\csw@delim.\csw@delim\csw@stop
	\csw@checkquestion #1\csw@delim?\csw@delim\csw@stop
	\csw@checkexclam   #1\csw@delim!\csw@delim\csw@stop
	\csw@checkcolon    #1\csw@delim:\csw@delim\csw@stop
	#1\ifcsw@haspunctuation\else.\fi
}

\def\csw@ignorewhitespaceandimplicitpars{%
	\begingroup
	\catcode13=10\relax
	\@ifnextchar\relax{\endgroup}{\endgroup}%
}

\NewDocumentCommand{\csw@paragraphhead}{m}{%
	\smallskip
	\noindent
	\textbf{\ignorespaces\csw@appendpunctuationifneeded{#1}}%
	\hskip 0.30em
	\ignorespaces
}

\NewDocumentCommand{\csw@subparagraphhead}{m}{%
	\smallskip
	\noindent
	\textsc{\ignorespaces\csw@appendpunctuationifneeded{#1}}%
	\hskip 0.30em
	\ignorespaces
}

\NewDocumentCommand{\parhead}   {m}{\csw@paragraphhead{#1}}
\NewDocumentCommand{\subparhead}{m}{\csw@subparagraphhead{#1}}

\AtBeginDocument{%
	\RenewDocumentCommand{\paragraph}{m}{\parhead{#1}}%
	\RenewDocumentCommand{\subparagraph}{m}{\subparhead{#1}}%
	\RenewDocumentCommand{\Pr}{}{\mathop{\mathsf{Pr}}}%
}

