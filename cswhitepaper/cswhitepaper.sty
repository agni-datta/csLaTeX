\providecommand{\csw@colorize}{\color{Firebrick2}}

\newcommand{\csw@brokenrefmark}[1]{
    \marginnote[
        {\csw@colorize\normalfont\smash{\LARGE$\star$}\,\tiny\sffamily#1}
    ]{
        {\csw@colorize\normalfont\smash{\LARGE$\star$}\,\tiny\sffamily#1}
    }
}

