%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\NewDocumentCommand{\commonheadfont} {}{\color{docucolor}\sffamily}
\NewDocumentCommand{\commonstartsymb}{}{\ensuremath{\color{docucolor}\diamond}~}
\NewDocumentCommand{\commonsymb}     {}{\ensuremath{\color{docucolor}\lrcorner}}

\ProvideDocumentCommand{\SetQEDSymbol}{m}{ \setqedsymbol{#1} }
\ProvideDocumentCommand{\SetTheoremEndSymbol}{m}{ \settheoremendsymbol{#1} }
\ProvideDocumentCommand{\setqedsymbol}{m}{ \RenewDocumentCommand{\qedsymbol}{}{#1} }
\ProvideDocumentCommand{\settheoremendsymbol}{m}{ \RenewDocumentCommand{\commonsymb}{}{#1} }

\mdfdefinestyle{csw@ruled}{%
	linewidth         = 1pt,%
	linecolor         = docucolor,%
	topline           = true,%
	bottomline        = true,%
	leftline          = false,%
	rightline         = false,%
	innertopmargin    = 6pt,%
	innerbottommargin = 6pt,%
	innerleftmargin   = 1pt,%
	innerrightmargin  = 1pt,%
	skipabove         = 6pt,%
	skipbelow         = 6pt%
}

\declaretheoremstyle[
	headfont     = \commonheadfont\commonstartsymb,
	notefont     = \normalfont,
	bodyfont     = \normalfont,
	spaceabove   = 0pt,
	spacebelow   = 0pt,
	headpunct    = {.},
	postheadspace = 0.5em ,
	mdframed      = { style = csw@ruled } ,
	qed          = \commonsymb
]{csw@theoremlike}

\declaretheoremstyle[
	headfont     = \commonheadfont\commonstartsymb,
	notefont     = \normalfont,
	bodyfont     = \normalfont,
	spaceabove   = 0pt,
	spacebelow   = 0pt,
	headpunct    = {.},
	postheadspace = 0.5em ,
	mdframed      = { style = csw@ruled } ,
	qed          = \commonsymb
]{csw@definitionlike}

\declaretheoremstyle[
	headfont     = \commonheadfont\commonstartsymb,
	notefont     = \normalfont,
	bodyfont     = \normalfont,
	spaceabove   = 0pt,
	spacebelow   = 0pt,
	headpunct    = {.},
	postheadspace = 0.5em ,
	mdframed      = { style = csw@ruled } ,
	qed          = \commonsymb
]{csw@remarklike}

\declaretheoremstyle[
	headfont     = \commonheadfont\commonstartsymb,
	notefont     = \normalfont,
	bodyfont     = \normalfont,
	spaceabove   = 0pt,
	spacebelow   = 0pt,
	headpunct    = {.},
	postheadspace = 0.5em ,
	mdframed      = { style = csw@ruled } ,
	qed          = \commonsymb
]{csw@highlightlike}

\declaretheoremstyle[
	headfont      = \itshape,
	bodyfont      = \normalfont,
	spaceabove    = 5pt,
	spacebelow    = 5pt,
	headpunct     = {.},
	postheadspace = 0.5em,
	qed           = {\qedsymbol}
]{csw@proofstyle}

\declaretheorem
[
	name         = Theorem ,
	style        = csw@theoremlike ,
	numberwithin = section
]{ theorem }
\RenewDocumentCommand{\qedsymbol}{}{\commonsymb}

\NewDocumentCommand{\csw@declaretheoremfamily}{mm}{%
	\forcsvlist{\declaretheorem[sibling=theorem,style=#1]}{#2}%
}

