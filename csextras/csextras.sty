% footnotes
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_if:NT \g_csextras_footnotes_bool
{
    \RequirePackage { bigfoot }
    \RequirePackage { footnote }
    \RequirePackage [ bottom , multiple , hang ] { footmisc }
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% orcid
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_if:NT \g_csextras_orcid_bool
{
    \RequirePackage { orcidlink }
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% informalheaders — titlesec section typography (article only)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_if:NT \g_csextras_informalheaders_bool
{
    \csextras_article_only:nn { informalheaders }
    {
        \RequirePackage { titlesec }
        \titleformat { \section }
        { \normalfont\Large\sffamily\color{accentcolor} }
        { \thesection }{ 0.75em }{}
        \titleformat { \subsection }
        { \normalfont\large\sffamily\color{accentcolor} }
        { \thesubsection }{ 0.65em }{}
        \titleformat { \subsubsection } [ runin ]
        { \normalfont\sffamily\color{accentcolor} }
        { \thesubsubsection }{ 0.55em }{}[.]
    }
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% beautify — apply color palette to document text elements
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_if:NT \g_csextras_beautify_bool
{
    \AtBeginDocument
    {
        \ExplSyntaxOff
        \@ifpackageloaded{caption}
        {
            \captionsetup{labelfont = {color = figurecolor , small , bf}}
        }{}
        \ExplSyntaxOn
    }
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% hyperrefcolors — apply standard TCS hyperref palette
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_if:NT \g_csextras_hyperrefcolors_bool
{
    \AtBeginDocument
    {
        \ExplSyntaxOff
        \@ifpackageloaded{hyperref}
        {
            \hypersetup
            {
                citecolor = RoyalBlue ,
                linkcolor = MidnightBlue ,
                urlcolor  = RedOrange ,
            }
        }
        {
            \PackageWarning{csextras}
            {hyperrefcolors=true: hyperref is not loaded.\MessageBreak
                Load hyperref (or a base package that loads it) first.}
        }
        \ExplSyntaxOn
    }
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% figureposition — publication-quality float placement parameters
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_if:NT \g_csextras_figureposition_bool
{
    \ExplSyntaxOff
    \renewcommand{\topfraction      }{0.92}
    \renewcommand{\bottomfraction   }{0.82}
    \renewcommand{\textfraction     }{0.06}
    \renewcommand{\floatpagefraction}{0.78}
    \providecommand{\enit@after}{}
    \ExplSyntaxOn
    \setcounter { topnumber    } { 3 }
    \setcounter { bottomnumber } { 2 }
    \setcounter { totalnumber  } { 4 }
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% numbering — secnumdepth and tocdepth
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_if:NT \g_csextras_numbering_bool
{
    \setcounter { secnumdepth } { 3 }
    \setcounter { tocdepth    } { 2 }
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% boxes — mdframed global setup + named environments
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_if:NT \g_csextras_boxes_bool
{
    \RequirePackage [ framemethod = TikZ ] { mdframed }
    \mdfsetup
    {
        innertopmargin    = 7.5pt ,
        innerbottommargin = 7.5pt ,
        innerleftmargin   = 7.5pt ,
        innerrightmargin  = 7.5pt ,
        linewidth         = 0.5pt ,
        nobreak           = true ,
        roundcorner       = 1.0pt ,
        skipabove         = 0.75\baselineskip ,
        skipbelow         = 0.75\baselineskip ,
    }
    \newmdenv
    [
        linecolor       = accentcolor!30 ,
        backgroundcolor = accentcolor!5 ,
    ]{ openproblemframe }
    \newmdenv
    [
        linecolor       = accentcolor!30 ,
        backgroundcolor = accentcolor!5 ,
    ]{ questionbox }
    \newmdenv
    [
        linecolor       = accentcolor!30 ,
        backgroundcolor = accentcolor!5 ,
    ]{ proofbox }
    \newmdenv
    [
        linecolor       = diagramborder ,
        backgroundcolor = diagrambackground!15 ,
    ]{ diagramframe }
    \newmdenv
    [
        linecolor       = diagramborder!50 ,
        backgroundcolor = white ,
    ]{ figurebox }
}

