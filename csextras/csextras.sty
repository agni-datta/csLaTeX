%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Engine guard
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\sys_if_engine_xetex:T
{
    \PackageError { csextras } { XeLaTeX~is~not~supported }
    {
        XeLaTeX~is~superseded~by~LuaLaTeX. \MessageBreak
        Switch~to~LuaLaTeX~(lualatex)~or~pdfLaTeX~(pdflatex).
    }
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% biblatex guard — incompatible with every bibliography feature here
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\msg_new:nnn { csextras } { biblatex-blocked }
{
    biblatex~is~not~compatible~with~csextras. \MessageBreak
    Use~natbib~via~crazybib=true,~or~the~built-in~bibliography \MessageBreak
    helpers~(bibliography=true).~Do~not~load~biblatex~alongside~csextras.
}

\ExplSyntaxOff
\@ifpackageloaded{biblatex}
{
    \PackageError{csextras}{biblatex already loaded}
    {%
        biblatex is not compatible with csextras.\MessageBreak
        Use natbib via crazybib=true, or the built-in bibliography\MessageBreak
        helpers (bibliography=true). Do not load biblatex alongside csextras.%
    }
}{}
\ExplSyntaxOn

\AddToHook { package / biblatex / before }
{
    \PackageError { csextras } { biblatex~load~attempted }
    { \msg_use:nn { csextras } { biblatex-blocked } }
}

