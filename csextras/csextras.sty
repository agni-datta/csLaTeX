% titlepage — authblk + titling custom style (article only)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_if:NT \g_csextras_titlepage_bool
{
    \csextras_article_only:nn { titlepage }
    {
        \RequirePackage { titling }
        \RequirePackage { authblk }
        \RenewDocumentCommand \Authfont  {} { \normalfont\large\sffamily\color{accentcolor}    }
