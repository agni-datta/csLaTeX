%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Mode detection and validation
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_if:nT { \g_csextras_article_bool && \g_csextras_book_bool }
{
    \PackageError { csextras } { article~and~book~are~mutually~exclusive }
    { Use~either~article=true~or~book=true,~not~both. }
}

\bool_if:NT \g_csextras_article_bool { \tl_gset:Nn \g_csextras_mode_tl { article } }
\bool_if:NT \g_csextras_book_bool    { \tl_gset:Nn \g_csextras_mode_tl { book    } }

\ExplSyntaxOff
\@ifpackageloaded{csamsmath}
{
    \ExplSyntaxOn
    \tl_if_eq:NnT \g_csextras_mode_tl { unknown } { \tl_gset:Nn \g_csextras_mode_tl { article } }
    \tl_if_eq:NnT \g_csextras_mode_tl { book }
    {
        \PackageWarning { csextras }
        { csamsmath~is~already~loaded~but~book=true~was~given. \MessageBreak
            Reverting~to~article~mode. }
        \tl_gset:Nn \g_csextras_mode_tl { article }
    }
    \ExplSyntaxOff
}{}

\@ifpackageloaded{csbook}
{
    \ExplSyntaxOn
    \tl_if_eq:NnT \g_csextras_mode_tl { unknown } { \tl_gset:Nn \g_csextras_mode_tl { book } }
    \tl_if_eq:NnT \g_csextras_mode_tl { article }
    {
        \PackageWarning { csextras }
        { csbook~is~already~loaded~but~article=true~was~given. \MessageBreak
            Reverting~to~book~mode. }
        \tl_gset:Nn \g_csextras_mode_tl { book }
    }
    \ExplSyntaxOff
}{}
\ExplSyntaxOn

\tl_if_eq:NnT \g_csextras_mode_tl { unknown }
{
    \PackageWarning { csextras }
    { No~base~mode~could~be~determined. \MessageBreak
        Pass~article=true~or~book=true,~or~load~csamsmath/csbook~first. \MessageBreak
        Mode-specific~features~will~be~silently~skipped. }
}

\cs_new_protected:Npn \csextras_article_only:nn #1 #2
{
    \tl_if_eq:NnTF \g_csextras_mode_tl { article }
    { #2 }
    {
        \PackageWarning { csextras }
        { `#1'~is~only~available~in~article~mode~(csamsmath). \MessageBreak
            Ignoring~in~book~mode. }
    }
}

\cs_new_protected:Npn \csextras_book_only:nn #1 #2
{
    \tl_if_eq:NnTF \g_csextras_mode_tl { book }
    { #2 }
    {
        \PackageWarning { csextras }
        { `#1'~is~only~available~in~book~mode~(csbook). \MessageBreak
            Ignoring~in~article~mode. }
    }
}

\cs_new_protected:Npn \csextras_nag:nn #1 #2
{
    \PackageWarning { csextras }
    {
        DISCOURAGED:~you~enabled~`#1'. \MessageBreak
        #2 \MessageBreak
        Proceeding~anyway.
    }
}

