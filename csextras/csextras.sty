%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% epigraph — styled epigraph, quotation environment, and dedication environment
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_if:NT \g_csextras_epigraph_bool
{
    \RequirePackage { epigraph }
    \ExplSyntaxOff
    \renewcommand{\epigraphflush }{flushright}
    \renewcommand{\textflush     }{flushright}
    \renewcommand{\sourceflush   }{flushright}
    \let \csextras@saved@epigraph \epigraph
    \ExplSyntaxOn
    \RenewDocumentCommand \epigraph { m m }
    {
        \csextras@saved@epigraph { \normalsize\sffamily #1 }
        { \medskip\footnotesize\scshape #2 }
    }
    \RenewDocumentEnvironment { quotation } {}
    {
        \par\vspace{0.35\baselineskip}
        \begin{center}
        \begin{minipage}{0.78\textwidth}
        \centering\small\itshape\color{accentcolor}
        {\Large\color{accentcolor}\textquotedblleft}\hspace{0.12em}\ignorespaces
    }
    {
        \hspace{0.08em}{\Large\color{accentcolor}\textquotedblright}
        \end{minipage}
        \end{center}
        \vspace{0.15\baselineskip}
    }
    \NewDocumentEnvironment { dedication } { m m }
    {
        \def \csextras@dedic@first { #1 }
        \def \csextras@dedic@last  { #2 }
        \clearpage
        \thispagestyle { empty }
        \vspace*{\fill}
        \begin{center}
        \itshape\ignorespaces
    }
    {
        \par\smallskip
        { \normalfont\scshape\csextras@dedic@first~{\large\csextras@dedic@last} }
        \end{center}
        \vspace*{\fill}
        \clearpage
    }
}

