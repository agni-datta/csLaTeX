%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% algorithm — newfloat + codelines + cleveref/zref names
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_if:NT \g_csextras_algorithm_bool
{
    \RequirePackage { newfloat }
    \IfFileExists { codelines.sty } { \RequirePackage { codelines } } {}
    \DeclareFloatingEnvironment
    [
        fileext   = loa ,
        listname  = { List~of~Algorithms } ,
        name      = Algorithm ,
        placement = !hbt
    ]{ algorithm }
    \AtBeginDocument
    {
        \ExplSyntaxOff
        \@ifpackageloaded{cleveref}
        {
            \Crefname{algorithm}{Algorithm}{Algorithms}
            \crefname{algorithm}{algorithm}{algorithms}
            \Crefname{clcodeii}{Line}{Lines}
            \Crefname{clcodei}{Line}{Lines}
            \crefname{clcodeii}{line}{lines}
            \crefname{clcodei}{line}{lines}
        }
        {
            \@ifpackageloaded{zref-clever}
            {
                \ExplSyntaxOn
                \zcRefTypeSetup { algorithm }
                {
                    Name-sg = Algorithm ,
                    name-sg = algorithm ,
                    Name-pl = Algorithms ,
                    name-pl = algorithms ,
                }
                \zcRefTypeSetup { clcodeii }
                {
                    Name-sg = Line ,
                    name-sg = line ,
                    Name-pl = Lines ,
                    name-pl = lines ,
                }
                \zcRefTypeSetup { clcodei }
                {
                    Name-sg = Line ,
                    name-sg = line ,
                    Name-pl = Lines ,
                    name-pl = lines ,
                }
                \ExplSyntaxOff
            }{}
        }
        \ExplSyntaxOn
    }
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% tikz — conservative diagram library suite + pgfplots
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_if:NT \g_csextras_tikz_bool
{
    \ExplSyntaxOff
    \RequirePackage { tikz }
    \RequirePackage { tikz-cd }
    \RequirePackage { tikzscale }
    \RequirePackage { pgfplots }
    \pgfplotsset { compat = 1.18 }
    \usetikzlibrary
    {
        arrows.meta,
        calc,
        decorations.markings,
        decorations.pathmorphing,
        fit,
        intersections,
        matrix,
        patterns,
        patterns.meta,
        positioning,
        shadows,
        shapes.geometric,
        tikzmark,
        trees
    }
    \ExplSyntaxOn
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% layout — geometry, spacing, float, equation numbering
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_if:NT \g_csextras_layout_bool
{
    \ExplSyntaxOff
    \@ifpackageloaded{geometry}
    { \geometry{letterpaper , margin = 1in} }
    { \RequirePackage[letterpaper , margin = 1in]{geometry} }
    \ExplSyntaxOn
    \linespread { 1.05 }
    \hbadness   = 10000
    \vbadness   = 10000
    \hfuzz      = 10pt
    \vfuzz      = 10pt
    \setlength \emergencystretch { 2em }
    \AtBeginDocument
    {
        \ExplSyntaxOff
        \@ifpackageloaded{amsmath}
        {
            \ExplSyntaxOn
            \numberwithin { equation } { section }
            \allowdisplaybreaks
            \ExplSyntaxOff
        }{}
        \ExplSyntaxOn
        \interfootnotelinepenalty = 10000
    }
}

