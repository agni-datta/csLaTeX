%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Theorem environments
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\ifllncstheorems
    \def\llncsundefenv#1{%
        \expandafter\let\csname#1\endcsname\@undefined
        \expandafter\let\csname end#1\endcsname\@undefined
        \@ifundefined{c@#1}{}{%
            \expandafter\let\csname c@#1\endcsname\@undefined
            \expandafter\let\csname the#1\endcsname\@undefined
            \expandafter\let\csname p@#1\endcsname\@undefined
            \expandafter\let\csname cl@#1\endcsname\@undefined
        }%
    }

    \def\llncsdeclarenumbered#1#2#3{%
        \@ifundefined{c@theorem}{%
            \if@envcntsect
                \@spxnthm{#1}{#2}[section]{#3}{\rmfamily}%
            \else
                \@spynthm{#1}{#2}{#3}{\rmfamily}%
                \if@envcntreset
                    \@addtoreset{#1}{section}%
                \else
                    \@addtoreset{#1}{chapter}%
                \fi
            \fi
        }{%
            \@spothm{#1}[theorem]{#2}{#3}{\rmfamily}%
        }%
    }
    \def\llncsdeclarebold#1#2{\llncsdeclarenumbered{#1}{#2}{\bfseries}}
    \def\llncsdeclaresc#1#2{\llncsdeclarenumbered{#1}{#2}{\scshape}}
    \def\llncsdeclaresf#1#2{\llncsdeclarenumbered{#1}{#2}{\sffamily}}

    \let\oldproof\proof
    \let\endoldproof\endproof

    \AtEndPreamble{%
        \forcsvlist{\llncsundefenv}{%
            application,%
            assertion,%
            assumption,%
            axiom,%
            claim*,%
            claim,%
            claimproof,%
            commentary,%
            conclusion,%
            conjecture*,%
            conjecture,%
            construction,%
            convention,%
            corollary*,%
            corollary,%
            criterion,%
            definition,%
            discussion,%
            example,%
            exercise,%
            experiment,%
            fact,%
            folklore,%
            guideline,%
            highlight,%
            hypothesis*,%
            hypothesis,%
            important,%
            informaltheorem*,%
            informaltheorem,%
            insight,%
            keypoint,%
            lemma*,%
            lemma,%
            metatheorem,%
            motivation,%
            notation,%
            notationabuse,%
            note,%
            observation,%
            openproblem*,%
            openproblem,%
            postulate,%
            problem,%
            property,%
            proposition,%
            protocol,%
            question,%
            recall,%
            remark,%
            result,%
            solution,%
            step,%
            summary,%
            syntax*,%
            syntax,%
            takeaway,%
            theorem*,%
            theorem,%
            tip,%
            warning,%
        }%

        \if@envcntsect
            \def\@thmcountersep{.}%
            \spnewtheorem{theorem}{Theorem}[section]{\bfseries}{\rmfamily}%
        \else
            \spnewtheorem{theorem}{Theorem}{\bfseries}{\rmfamily}%
            \if@envcntreset
                \@addtoreset{theorem}{section}%
            \else
                \@addtoreset{theorem}{chapter}%
            \fi
        \fi

        \llncsdeclarebold{application}{Application}
        \llncsdeclarebold{assertion}{Assertion}
        \llncsdeclarebold{assumption}{Assumption}
        \llncsdeclarebold{axiom}{Axiom}
        \llncsdeclarebold{claim}{Claim}
        \llncsdeclarebold{conclusion}{Conclusion}
        \llncsdeclarebold{conjecture}{Conjecture}
        \llncsdeclarebold{construction}{Construction}
        \llncsdeclarebold{convention}{Convention}
        \llncsdeclarebold{corollary}{Corollary}
        \llncsdeclarebold{criterion}{Criterion}
        \llncsdeclarebold{definition}{Definition}
        \llncsdeclarebold{experiment}{Experiment}
        \llncsdeclarebold{fact}{Fact}
        \llncsdeclarebold{folklore}{Folklore}
        \llncsdeclarebold{hypothesis}{Hypothesis}
        \llncsdeclarebold{informaltheorem}{Informal Theorem}
        \llncsdeclarebold{lemma}{Lemma}
        \llncsdeclarebold{metatheorem}{Meta Theorem}
        \llncsdeclarebold{notation}{Notation}
        \llncsdeclarebold{observation}{Observation}
        \llncsdeclarebold{openproblem}{Open Problem}
        \llncsdeclarebold{postulate}{Postulate}
        \llncsdeclarebold{problem}{Problem}
        \llncsdeclarebold{property}{Property}
        \llncsdeclarebold{proposition}{Proposition}
        \llncsdeclarebold{protocol}{Protocol}
        \llncsdeclarebold{result}{Result}
        \llncsdeclarebold{solution}{Solution}
        \llncsdeclarebold{step}{Step}

        \llncsdeclaresc{commentary}{Commentary}
        \llncsdeclaresc{discussion}{Discussion}
        \llncsdeclaresc{example}{Example}
        \llncsdeclaresc{exercise}{Exercise}
        \llncsdeclaresc{motivation}{Motivation}
        \llncsdeclaresc{notationabuse}{Notation Abuse}
        \llncsdeclaresc{note}{Note}
        \llncsdeclaresc{question}{Question}
        \llncsdeclaresc{remark}{Remark}
        \llncsdeclaresc{syntax}{Syntax}

        \llncsdeclaresf{guideline}{Guideline}
        \llncsdeclaresf{highlight}{Highlight}
        \llncsdeclaresf{important}{Important point}
        \llncsdeclaresf{insight}{Insight}
        \llncsdeclaresf{keypoint}{Key Point}
        \llncsdeclaresf{recall}{Recall}
        \llncsdeclaresf{summary}{Summary}
        \llncsdeclaresf{takeaway}{Takeaway}
        \llncsdeclaresf{tip}{Tip}
        \llncsdeclaresf{warning}{Warning}

        \spnewtheorem*{claim*}{Claim}{\bfseries}{\rmfamily}
        \spnewtheorem*{conjecture*}{Conjecture}{\bfseries}{\rmfamily}
        \spnewtheorem*{corollary*}{Corollary}{\bfseries}{\rmfamily}
        \spnewtheorem*{hypothesis*}{Hypothesis}{\bfseries}{\rmfamily}
        \spnewtheorem*{informaltheorem*}{Informal Theorem}{\bfseries}{\rmfamily}
        \spnewtheorem*{lemma*}{Lemma}{\bfseries}{\rmfamily}
        \spnewtheorem*{openproblem*}{Open Problem}{\scshape}{\rmfamily}
        \spnewtheorem*{syntax*}{Syntax}{\scshape}{\rmfamily}
        \spnewtheorem*{theorem*}{Theorem}{\bfseries}{\rmfamily}

        \AtEndEnvironment{proof}{\qed}

        \ProvideDocumentCommand{\SetQEDSymbol}{m}{ \setqedsymbol{#1} }
        \ProvideDocumentCommand{\setqedsymbol}{m}{ \RenewDocumentCommand{\qedsymbol}{}{#1} }

        \NewDocumentEnvironment{proofsketch}{o}
        {
            \IfNoValueTF{#1}
            { \begin{proof}[Proof~(Sketch)] }
            { \begin{proof}[Proof~(Sketch~#1)] }
        }
        { \end{proof} }
        \NewDocumentEnvironment{proofidea}{o}
        {
            \IfNoValueTF{#1}
            { \begin{proof}[Proof~(Idea)] }
            { \begin{proof}[Proof~(Idea~#1)] }
        }
        { \end{proof} }
        \NewDocumentEnvironment{proofofclaim}{o}
        {
            \IfNoValueTF{#1}
            { \begin{proof}[Proof~of~Claim] }
            { \begin{proof}[Proof~of~Claim~(#1)] }
        }
        { \end{proof} }
        \NewDocumentEnvironment{claimproof}{O{Proof of Claim}}{\begin{proof}[#1]}{\end{proof}}
    }
\fi

