%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Boxes and framed environments
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\long\def\llncscustomfbox#1#2#3#4#5#6#7#8#9{%
    \leavevmode\begingroup
    \setbox\@tempboxa\hbox{\color@begingroup\kern\fboxsep{#9}\kern\fboxsep\color@endgroup}%
    \hbox{%
        \begingroup
        \@tempdima#4\relax
        \advance\@tempdima\fboxsep
        \advance\@tempdima\dp\@tempboxa
        \expandafter\endgroup\expandafter
        \lower\the\@tempdima\hbox{\vbox{%
                \hrule\@height#3\@width#7\relax
                #1%
                \hbox{%
                    \vrule\@width#5\relax
                    \hspace{#8}%
                    \vbox{\vskip\fboxsep\copy\@tempboxa\vskip\fboxsep}%
                    \vrule\@width#6\relax}%
                #2%
                \hrule\@height#4\@width#7\relax}}%
    }%
    \endgroup
}
\def\llncsopenfbox#1#2{%
    \fboxsep\FrameSep
    \llncscustomfbox{}{}{#1}{#2}\FrameRule\z@{1em}{0.4em}%
}
\NewDocumentEnvironment{nestedbar}{O{\hsize}}{%
    \@ifundefined{OuterFrameSep}{\@latex@error{nestedbar requires a recent framed.sty}\@ehd}{}%
    \def\FrameCommand{\llncsopenfbox\FrameRule\FrameRule}%
    \def\FirstFrameCommand{\llncsopenfbox\FrameRule\z@}%
    \def\MidFrameCommand{\llncsopenfbox\z@\z@}%
    \def\LastFrameCommand{\llncsopenfbox\z@\FrameRule}%
    \OuterFrameSep=1ex\FrameSep=0pt
    \MakeFramed{\hsize#1\advance\hsize-\width\FrameRestore}%
    \smallskip
}{%
    \smallskip
    \endMakeFramed
}

\RequirePackage[
    skipabove   = 0.75\baselineskip ,
    skipbelow   = 0.75\baselineskip ,
    framemethod = default
]{mdframed}
\mdfdefinestyle{llncsbox}{
    font              = \small ,
    roundcorner       = 1.0pt ,
    linewidth         = 0.5pt ,
    nobreak           = true ,
    skipabove         = 0.75\baselineskip ,
    skipbelow         = 0.75\baselineskip ,
    innerleftmargin   = 7.5pt ,
    innerrightmargin  = 7.5pt ,
    innertopmargin    = 7.5pt ,
    innerbottommargin = 7.5pt ,
    backgroundcolor   = white ,
    linecolor         = black
}
\NewDocumentCommand{\llncsboxtitle}{o}{%
    \IfNoValueF{#1}{%
        \noindent\textbf{\small#1}\par\smallskip
        \noindent\hrule height 0.4pt\relax\vspace{0.4\baselineskip}%
    }%
}
\NewDocumentEnvironment{simplebox}{o}{%
    \begin{mdframed}[style=llncsbox]%
    \llncsboxtitle[#1]%
}{%
    \end{mdframed}%
}

