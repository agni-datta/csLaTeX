\newif\ifllncshaspunct
\def\llncscheckpunct#1{\ifx\llncscheckpunct#1\llncscheckpunct\else\llncshaspuncttrue\fi}
\def\llncscheckdot#1.\llncssep#2\llncsend{\llncscheckpunct{#2}}
\def\llncscheckquestion#1?\llncssep#2\llncsend{\llncscheckpunct{#2}}
\def\llncscheckexclam#1!\llncssep#2\llncsend{\llncscheckpunct{#2}}
\def\llncscheckcolon#1:\llncssep#2\llncsend{\llncscheckpunct{#2}}

\NewDocumentCommand{\llncsappendpunct}{m}{%
    \llncshaspunctfalse
    \llncscheckdot#1\llncssep.\llncssep\llncsend
    \llncscheckquestion#1\llncssep?\llncssep\llncsend
    \llncscheckexclam#1\llncssep!\llncssep\llncsend
    \llncscheckcolon#1\llncssep:\llncssep\llncsend
    #1\ifllncshaspunct\else.\fi
}
