		}\par\medskip
	}%
	\ifllncs@notes\llncs@appenddnote{Missing}{BrickRed}{#1}\fi
	\textcolor{BrickRed}{#1}%
}
\newcommand{\printmissing}{%
	\section*{Missing Content}%
	\llncs@missinglist
}

