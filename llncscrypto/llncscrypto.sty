\newif\ifllncs@haspunct
\def\llncs@testchar#1{%
	\ifx\llncs@testchar#1\llncs@testchar\else\llncs@haspuncttrue\fi}
\def\llncs@testdot  #1.\llncs@e#2\llncs@s  {\llncs@testchar{#2}}
\def\llncs@testquest#1?\llncs@e#2\llncs@s  {\llncs@testchar{#2}}
\def\llncs@testexclam#1!\llncs@e#2\llncs@s {\llncs@testchar{#2}}
\def\llncs@testcolon#1:\llncs@e#2\llncs@s  {\llncs@testchar{#2}}
\newcommand{\llncs@autopunct}[1]{%
	\llncs@haspunctfalse
	\llncs@testdot  #1\llncs@e.\llncs@e\llncs@s
	\llncs@testquest#1\llncs@e?\llncs@e\llncs@s
	\llncs@testexclam#1\llncs@e!\llncs@e\llncs@s
	\llncs@testcolon#1\llncs@e:\llncs@e\llncs@s
	#1\ifllncs@haspunct\else.\fi
}

\def\llncs@skipspaces{%
	\begingroup\catcode13=10
	\@ifnextchar\relax{\endgroup}{\endgroup}%
}

\newcommand{\parheadnoperiod}[1]{%
	\smallskip\noindent
	{\bfseries\boldmath\ignorespaces#1}%
	\hskip0.9em plus 0.3em minus 0.3em
