}

\newcommand{\subparheadnoperiod}[1]{%
	\smallskip\noindent
	{\scshape\boldmath\ignorespaces#1}%
	\hskip0.9em plus 0.3em minus 0.3em
	\llncs@skipspaces
}

\newcommand{\parhead}[1]{\parheadnoperiod{\llncs@autopunct{#1}}}
\renewcommand{\paragraph}[1]{\parhead{#1}}

\newcommand{\subparhead}[1]{\subparheadnoperiod{\llncs@autopunct{#1}}}
\renewcommand{\subparagraph}[1]{\subparhead{#1}}

\long\def\llncs@CustomFBox#1#2#3#4#5#6#7#8#9{%
	\leavevmode\begingroup
	\setbox\@tempboxa\hbox{
		\color@begingroup\kern\fboxsep{#9}\kern\fboxsep\color@endgroup}%
	\hbox{%
		\begingroup
		\@tempdima#4\relax
		\advance\@tempdima\fboxsep
		\advance\@tempdima\dp\@tempboxa
		\expandafter\endgroup\expandafter
		\lower\the\@tempdima\hbox{\vbox{%
				\hrule\@height#3\@width#7\relax
				#1%
				\hbox{%
					\vrule\@width#5\relax
					\hspace{#8}%
					\vbox{\vskip\fboxsep\copy\@tempboxa\vskip\fboxsep}%
					\vrule\@width#6\relax}%
				#2%
				\hrule\@height#4\@width#7\relax}}%
	}%
	\endgroup
}

\newcommand{\llncs@nb@hrlen}{1em}
\newcommand{\llncs@nb@indent}{0.4em}

\def\llncs@OpenFBox#1#2{%
	\fboxsep\FrameSep
	\llncs@CustomFBox{}{}{#1}{#2}\FrameRule\z@
	{\llncs@nb@hrlen}{\llncs@nb@indent}%
}

\newenvironment{nestedbar}[1][\hsize]{%
	\@ifundefined{OuterFrameSep}{%
		\@latex@error{nestedbar requires a recent framed.sty}\@ehd}{}%
	\def\FrameCommand     {\llncs@OpenFBox\FrameRule\FrameRule}%
	\def\FirstFrameCommand{\llncs@OpenFBox\FrameRule\z@}%
	\def\MidFrameCommand  {\llncs@OpenFBox\z@\z@}%
	\def\LastFrameCommand {\llncs@OpenFBox\z@\FrameRule}%
	\OuterFrameSep=1ex\FrameSep=0pt
	\MakeFramed{\hsize#1\advance\hsize-\width\FrameRestore}%
	\smallskip
}{\smallskip\endMakeFramed}

\newcommand{\emailref}[1]{\href{mailto:#1}{\nolinkurl{#1}}}
\newcommand{\httpref}[1] {\href{http://#1}{\nolinkurl{#1}}}

\newcommand{\footnotesymb}[2]{%
	\def\@tempa{#1}%
	\ifx\@tempa\@empty
		\let\llncs@savedmakefntext\@makefntext
		\long\def\@makefntext##1{\parindent1em\noindent##1}%
		{\protected@xdef\@thefnmark{}}%
		\@footnotetext{#2}%
		\let\@makefntext\llncs@savedmakefntext
	\else
		{\protected@xdef\@thefnmark{#1}}\@footnotemark\@footnotetext{#2}%
	\fi
}

