\NewDocumentCommand{\footnotesymb}{m m}{%
    \def\@tempa{#1}%
    \ifx\@tempa\@empty
        \let\llncssavedmakefntext\@makefntext
        \long\def\@makefntext##1{\parindent1em\noindent##1}%
        {\protected@xdef\@thefnmark{}}%
        \@footnotetext{#2}%
        \let\@makefntext\llncssavedmakefntext
    \else
        {\protected@xdef\@thefnmark{#1}}\@footnotemark\@footnotetext{#2}%
    \fi
}
