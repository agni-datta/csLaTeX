            $\star$~\thellncsmissing~(p.~\pageref{llncs:missing:\thellncsmissing}):~#1%
        }\par\medskip
    }%
    \ifllncsnotes\llncsappenddnote{Missing}{DeepPink2}{#1}\fi
    \textcolor{DeepPink2}{#1}%
}
