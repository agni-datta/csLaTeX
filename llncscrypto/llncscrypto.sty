%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Notes and draft annotations
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\definecolor{llncsnotecolor}{rgb}{0.52,0.20,0.52}

\newbool{llncsinfootnote}
\newbool{llncsintabular}
\newbool{llncsinminipage}
\newbool{llncsinframed}

\let\llncsoldfootnote\footnote
\RenewDocumentCommand{\footnote}{o m}{%
    {\booltrue{llncsinfootnote}%
        \IfNoValueTF{#1}{\llncsoldfootnote{#2}}{\llncsoldfootnote[#1]{#2}}}%
    \boolfalse{llncsinfootnote}%
}

\BeforeBeginEnvironment{tabular}{\booltrue{llncsintabular}}
\AfterEndEnvironment{tabular}{\boolfalse{llncsintabular}}
\BeforeBeginEnvironment{minipage}{\booltrue{llncsinminipage}}
\AfterEndEnvironment{minipage}{\boolfalse{llncsinminipage}}

\AtBeginDocument{%
    \@ifpackageloaded{framed}{%
        \xpretocmd{\MakeFramed}{\booltrue{llncsinframed}}{}{}%
        \xapptocmd{\endMakeFramed}{\boolfalse{llncsinframed}}{}{}%
    }{}%
}

\NewDocumentCommand{\sidenote}{m}{%
    \ifboolexpr{
        bool {llncsinfootnote} or
        bool {llncsintabular} or
        bool {llncsinminipage} or
        bool {llncsinframed}
    }{\marginnote{\tiny#1}}{\marginpar{\tiny#1}}%
}

\newcounter{llncsdnote}
\def\llncsdnotelist{}
\NewDocumentCommand{\llncsappenddnote}{m m m}{%
    \refstepcounter{llncsdnote}%
    \label{llncs:note:\thellncsdnote}%
    \expandafter\gdef\csname llncsnoteauthor\thellncsdnote\endcsname{#1}%
    \expandafter\gdef\csname llncsnotecolor\thellncsdnote\endcsname{#2}%
    \expandafter\gdef\csname llncsnotetext\thellncsdnote\endcsname{#3}%
    \edef\llncscurrentnote{\thellncsdnote}%
    \expandafter\gappto\expandafter\llncsdnotelist
    \expandafter{\expandafter\llncsemitdnote\expandafter{\llncscurrentnote}}%
}
\NewDocumentCommand{\llncsemitdnote}{m}{%
    \noindent
    {\color{\csname llncsnotecolor#1\endcsname}\normalfont$\bigstar$}~%
    \ifcsvoid{llncsnoteauthor#1}{}{%
        {\small\itshape\csname llncsnoteauthor#1\endcsname:\enspace}%
    }%
    {\color{\csname llncsnotecolor#1\endcsname}\small\sffamily\bfseries
        \csname llncsnotetext#1\endcsname}%
    \hfill{\small\normalfont(p.~\pageref{llncs:note:#1})}\par\smallskip
}

\ifllncsnotes
    \NewDocumentCommand{\dtcolornote}{O{} m m}{%
        \llncsappenddnote{#1}{#2}{#3}%
        \sidenote{{\color{#2}\normalfont$\bigstar$}}%
        \ifmmode\expandafter\mbox\fi{%
        {\color{#2}\sffamily\bfseries\boldmath
            [#3\ifstrempty{#1}{}{{\mdseries\itshape~-- #1}}]}%
        }%
    }
    \NewDocumentCommand{\dtnote}{O{} m}{\dtcolornote[#1]{llncsnotecolor}{#2}}
    \NewDocumentCommand{\dtignore}{O{} m}{%
        \sidenote{{\color{llncsnotecolor}\normalfont$\looparrowright$\scriptsize~#1}}%
    }
    \NewDocumentCommand{\XXX}{O{XXX}}{%
        \sidenote{{\color{PaleVioletRed3}\normalfont$\star$}}%
        {\color{PaleVioletRed3}\sffamily\bfseries[#1]}%
    }
    \NewDocumentCommand{\added}{m}{\textcolor{OliveGreen}{#1}\marginnote{\textcolor{OliveGreen}{\LARGE$\star$}}}
    \NewDocumentCommand{\changed}{m}{\textcolor{PineGreen}{#1}\marginnote{\textcolor{PineGreen}{\LARGE$\star$}}}
    \NewDocumentCommand{\citelater}{m}{\textcolor{WildStrawberry}{[#1]}\marginnote{\textcolor{WildStrawberry}{\LARGE$\star$}}}
    \NewDocumentCommand{\fixme}{m}{\textcolor{OrangeRed}{[\textsc{Fix-me}: #1]}\marginnote{\textcolor{OrangeRed}{\LARGE$\star$}}}
    \NewDocumentCommand{\notes}{m}{\textcolor{ForestGreen}{[\textsc{Note}: #1]}\marginnote{\textcolor{ForestGreen}{\LARGE$\star$}}}
    \NewDocumentCommand{\query}{m}{\textcolor{RoyalPurple}{[\textsc{Query}: #1]}\marginnote{\textcolor{RoyalPurple}{\LARGE$\star$}}}
    \NewDocumentCommand{\removed}{m}{\textcolor{Periwinkle}{\sout{#1}}\marginnote{\textcolor{Periwinkle}{\LARGE$\star$}}}
    \NewDocumentCommand{\todo}{m}{\textcolor{Mahogany}{[\textsc{To-do}: #1]}\marginnote{\textcolor{Mahogany}{\LARGE$\star$}}}
\else
    \NewDocumentCommand{\dtcolornote}{O{} m m}{\ignorespaces}
    \NewDocumentCommand{\dtnote}{O{} m}{\ignorespaces}
