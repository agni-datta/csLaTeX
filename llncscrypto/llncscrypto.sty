\newcounter{llncs@dnote}
\newcommand{\llncs@dnotelist}{}
\newcommand{\llncs@appenddnote}[3]{%
	\refstepcounter{llncs@dnote}%
	\label{llncs@dn:\thellncs@dnote}%
	\expandafter\long\expandafter\def
	\csname llncs@dn@a@\thellncs@dnote\endcsname{#1}%
	\expandafter\def
	\csname llncs@dn@c@\thellncs@dnote\endcsname{#2}%
	\expandafter\long\expandafter\def
	\csname llncs@dn@t@\thellncs@dnote\endcsname{#3}%
	\edef\llncs@dn@cur{\thellncs@dnote}%
	\expandafter\gappto\expandafter\llncs@dnotelist
	\expandafter{\expandafter\llncs@dnotelist@emit\expandafter{\llncs@dn@cur}}%
}
\newcommand{\llncs@dnotelist@emit}[1]{%
	\noindent
	{\color{\csname llncs@dn@c@#1\endcsname}\normalfont$\bigstar$}~%
	\expandafter\ifx\csname llncs@dn@a@#1\endcsname\@empty\else
		{\small\itshape\csname llncs@dn@a@#1\endcsname:\enspace}%
	\fi
	{\color{\csname llncs@dn@c@#1\endcsname}\small\sffamily\bfseries
		\csname llncs@dn@t@#1\endcsname}%
	\hfill{\small\normalfont(p.~\pageref{llncs@dn:#1})}\par\smallskip
}

\ifllncs@notes
	\newcommand{\dtcolornote}[3][]{%
		\llncs@appenddnote{#1}{#2}{#3}%
		\sidenote{{\color{#2}\normalfont$\bigstar$}}%
		\ifmmode\expandafter\mbox\fi{%
		{\color{#2}\smaller\sffamily\bfseries\boldmath
			[#3\ifx\relax#1\relax\else{\mdseries\itshape~---#1}\fi]}%
		}%
	}
	\newcommand{\dtnote}[2][]{\dtcolornote[#1]{llncs@notecolor}{#2}}
	\newcommand{\XXX}[1][XXX]{%
		\sidenote{{\color{red}\normalfont$\blacktriangleright$}}%
		{\color{red}\smaller\sffamily\bfseries[#1]}%
	}
	\newcommand{\dtignore}[2][]{%
		\sidenote{{\color{llncs@notecolor}\normalfont$\looparrowright$\scriptsize~#1}}%
	}
\else
	\newcommand{\dtcolornote}[3][]{\ignorespaces}
	\newcommand{\dtnote}[2][]{\ignorespaces}
	\newcommand{\XXX}[1][XXX]{%
		\@latex@error{%
			\string\XXX{} found but notes are disabled (camera or nonotes option)%
		}\@ehd
	}
	\newcommand{\dtignore}[2][]{\ignorespaces}
\fi

\newcommand{\printdtnotes}{%
	\ifnum\value{llncs@dnote}>0
		\section*{Author Notes}%
		\llncs@dnotelist
	\fi
}

