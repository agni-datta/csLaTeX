    \fancypagestyle{llncspreprint}{%
        \fancyhf{}%
        \fancyfoot[C]{\small\thepage}%
        \RenewDocumentCommand{\headrulewidth}{}{0pt}%
        \RenewDocumentCommand{\footrulewidth}{}{0pt}%
    }
    \AtBeginDocument{\pagestyle{llncspreprint}}
    \AtBeginDocument{%
        \ifnum\@ptsize=1\else
            \PackageWarning{llncscrypto}{preprint mode expects [11pt] in \string\documentclass}%
        \fi
    }
    \let\llncsoldtitle\title
    \RenewDocumentCommand{\title}{m}{\llncsoldtitle{\LARGE\normalfont\bfseries#1}}
    \NewDocumentCommand{\preprint}{O{}O{}}{%
        \AtEndPreamble{%
            \fancypagestyle{llncspreprint}{%
                \fancyhf{}%
                \IfValueT{#1}{\fancyhead[L]{\small\textsc{#1}}}%
                \IfValueT{#2}{\fancyhead[R]{\small\textsc{#2}}}%
                \fancyfoot[C]{\small\thepage}%
                \RenewDocumentCommand{\headrulewidth}{}{0pt}%
                \RenewDocumentCommand{\footrulewidth}{}{0pt}%
            }%
        }%
    }
\fi

