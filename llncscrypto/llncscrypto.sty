%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Options
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_new:N \g_llncs_captions_bool
\bool_new:N \g_llncs_colorlinks_bool
\bool_new:N \g_llncs_draft_bool
\bool_new:N \g_llncs_final_bool
\bool_new:N \g_llncs_libertine_bool
\bool_new:N \g_llncs_notes_bool
\bool_new:N \g_llncs_preprint_bool
\bool_new:N \g_llncs_theorems_bool

\keys_define:nn { llncscrypto }
{
    captions   .bool_gset:N = \g_llncs_captions_bool   , captions   .initial:n = false ,
    colorlinks .bool_gset:N = \g_llncs_colorlinks_bool , colorlinks .initial:n = false ,
    draft      .bool_gset:N = \g_llncs_draft_bool      , draft      .initial:n = false ,
    final      .code:n      = { \bool_gset_true:N  \g_llncs_final_bool
            \bool_gset_false:N \g_llncs_notes_bool
            \bool_gset_false:N \g_llncs_draft_bool } ,
    final      .initial:n   = false ,
    libertine  .bool_gset:N = \g_llncs_libertine_bool  , libertine  .initial:n = false ,
    nonotes    .code:n      = { \bool_gset_false:N \g_llncs_notes_bool } ,
    preprint   .bool_gset:N = \g_llncs_preprint_bool   , preprint   .initial:n = false ,
    theorems   .bool_gset:N = \g_llncs_theorems_bool   , theorems   .initial:n = false ,
    unknown    .code:n      = { \PackageWarning{llncscrypto}{Unknown~option~`#1'} } ,
}
\bool_gset_true:N \g_llncs_notes_bool
\ProcessKeysOptions { llncscrypto }

\newif\ifllncscaptions   \bool_if:NTF \g_llncs_captions_bool   { \llncscaptionstrue   } { \llncscaptionsfalse   }
\newif\ifllncscolorlinks \bool_if:NTF \g_llncs_colorlinks_bool { \llncscolorlinkstrue } { \llncscolorlinksfalse }
\newif\ifllncsdraft      \bool_if:NTF \g_llncs_draft_bool      { \llncsdrafttrue      } { \llncsdraftfalse      }
\newif\ifllncsfinal      \bool_if:NTF \g_llncs_final_bool      { \llncsfinaltrue      } { \llncsfinalfalse      }
\newif\ifllncslibertine  \bool_if:NTF \g_llncs_libertine_bool  { \llncslibertinetrue  } { \llncslibertinefalse  }
\newif\ifllncsnotes      \bool_if:NTF \g_llncs_notes_bool      { \llncsnotestrue      } { \llncsnotesfalse      }
\newif\ifllncspreprint   \bool_if:NTF \g_llncs_preprint_bool   { \llncspreprinttrue   } { \llncspreprintfalse   }
\newif\ifllncstheorems   \bool_if:NTF \g_llncs_theorems_bool   { \llncstheoremstrue   } { \llncstheoremsfalse   }

\ExplSyntaxOff

