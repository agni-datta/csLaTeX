\newcommand{\newsequenceofgames}[1]{
	\newcounter{#1}
	\setcounter{#1}{-1}
	\def\sequencename{#1}
	\ifx\GameID\undefined
		\newcommand{\GameID}{#1}
	\else
		\renewcommand{\GameID}{#1}
	\fi
	\ifx\PrevLabel\undefined
		\newcommand{\PrevLabel}{\GameID.NULL}
	\else
		\renewcommand{\PrevLabel}{\GameID.NULL}
	\fi
	\ifx\ThisLabel\undefined
		\newcommand{\ThisLabel}{\GameID.NULL}
	\else
		\renewcommand{\ThisLabel}{\GameID.NULL}
	\fi
}

\newcommand{\nextgame}[1]{
	\let\PrevLabel\ThisLabel
	\renewcommand{\ThisLabel}{\GameID.#1}
	\refstepcounter{\GameID}\label{\GameID.#1}
	\paragraph{Experiment~$\algostyle{Exp}_\arabic{\GameID}.$}
}
\newcommand{\nextgamewithref}[2]{
	\let\PrevLabel\ThisLabel
	\renewcommand{\ThisLabel}{\GameID.#1}
	\refstepcounter{\GameID}\label{\GameID.#1}
	\paragraph{Game~\hyperref[#2]{$\algostyle{G}_{\arabic{\GameID}}$}}
}
\newcommand{\nextgamewithrefi}[3]{
	\let\PrevLabel\ThisLabel
	\renewcommand{\ThisLabel}{\GameID.#1}
	\refstepcounter{\GameID}\label{\GameID.#1}
	\paragraph{Game~\hyperref[#2]{$\algostyle{G}_{\arabic{\GameID}.#3}$}}
}

\newcommand{\gameref}[1]{{\hyperref[\sequencename.#1]{\algostyle{G}_{\ref{\sequencename.#1}}}}}
\newcommand{\gamerefi}[2]{{\hyperref[\sequencename.#1]{\algostyle{G}_{\ref{\sequencename.#1}.#2}}}}
\newcommand{\gamerefA}[1]{{\hyperref[\sequencename.#1]{\algostyle{G}^{\advA}_{\ref{\sequencename.#1}}}}}
\newcommand{\gamerefAi}[2]{{\hyperref[\sequencename.#1]{\algostyle{G}^{\advA}_{\ref{\sequencename.#1}.#2}}}}

\newcommand{\gamedelta}[2]{
	\Pr\left[\gamerefA{#1}\Rightarrow 1\right]
	- \Pr\left[\gamerefA{#2}\Rightarrow 1\right]}
\newcommand{\gameequal}[2]{
	\Pr\left[\gamerefA{#1}\Rightarrow 1\right]
	= \Pr\left[\gamerefA{#2}\Rightarrow 1\right]}

