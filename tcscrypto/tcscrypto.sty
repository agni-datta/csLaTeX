\if@tcscrypto@small
	\NewDocumentCommand{\tcs@reducesize}{}{%
		\ifx\@currsize\normalsize\small
		\else
			\ifx\@currsize\small\footnotesize
			\else
				\ifx\@currsize\large\normalsize
				\fi
			\fi
		\fi
	}
	\NewDocumentCommand{\tcs@possiblymakesmaller}{m}{%
		\mathchoice
		{\hbox{\tcs@reducesize$#1$}}%
		{\hbox{\tcs@reducesize$#1$}}%
		{#1}%
		{#1}%
	}%
	\NewDocumentCommand{\algostyle}{m}{%
		\ensuremath{\hbox{\tcs@reducesize$\mathsf{#1}$%
			}%
		}%
	}%
\else
	\NewDocumentCommand{\algostyle}{m}{\ensuremath{\mathsf{#1}}}
\fi

