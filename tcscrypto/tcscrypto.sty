\ExplSyntaxOn

\cs_new_protected:Npn \__crypto_define_one:nnnn #1#2#3#4
{
	\cs_if_free:cT { #1#2 }
	{ \cs_new:cpn { #1#2 } { \use:c { #4 } { #3 } } }
}

\cs_new_protected:Npn \__crypto_parse_pair:w #1/#2 \q_stop #3#4
{ \__crypto_define_one:nnnn { #3 } { #1 } { #2 } { #4 } }

\NewDocumentCommand \cryptoDefineAlgoCSV { m }
{ \clist_map_inline:nn { #1 } { \__crypto_parse_pair:w ##1 \q_stop { } { algostyle } } }

\NewDocumentCommand \cryptoDefineClassCSV { m }
{ \clist_map_inline:nn { #1 } { \__crypto_parse_pair:w ##1 \q_stop { } { funcstyle } } }

\NewDocumentCommand \cryptoDefineComplexityClassCSV { m }
{ \clist_map_inline:nn { #1 } { \__crypto_parse_pair:w ##1 \q_stop { } { ComplexityFont } } }

\NewDocumentCommand \cryptoDefineKeyCSV { m }
{ \clist_map_inline:nn { #1 } { \__crypto_parse_pair:w ##1 \q_stop { } { keystyle } } }

\NewDocumentCommand \cryptoDefineSchemeCSV { m }
{ \clist_map_inline:nn { #1 } { \__crypto_parse_pair:w ##1 \q_stop { } { schemestyle } } }

\NewDocumentCommand \cryptoDefineOracleCSV { m }
{ \clist_map_inline:nn { #1 } { \__crypto_parse_pair:w ##1 \q_stop { } { oraclestyle } } }

\NewDocumentCommand \cryptoDefineProbCSV { m }
{ \clist_map_inline:nn { #1 } { \__crypto_parse_pair:w ##1 \q_stop { } { probstyle } } }

\NewDocumentCommand{\mbf}{m}
{
	\regex_match:nnTF { \A [a-zA-Z0-9] \Z } { #1 }
	{ \mathbf{#1} }{ \boldsymbol{#1} }
}

\tl_new:N \l_tcsc_letter_tl

\int_step_inline:nnn { 1 } { 26 }
{
	\tl_set:Nx \l_tcsc_letter_tl { \int_to_Alph:n { #1 } }
	\cs_if_free:cT { adv \l_tcsc_letter_tl } { \cs_new:cpx { adv \l_tcsc_letter_tl } { \exp_not:N \ensuremath { { \exp_not:N \mathsf { \l_tcsc_letter_tl } } } } }
	\cs_if_free:cT { bb \l_tcsc_letter_tl } { \cs_new:cpx { bb \l_tcsc_letter_tl } { \exp_not:N \ensuremath { { \exp_not:N \mathbb { \l_tcsc_letter_tl } } } } }
	\cs_if_free:cT { bf \l_tcsc_letter_tl } { \cs_new:cpx { bf \l_tcsc_letter_tl } { \exp_not:N \ensuremath { { \exp_not:N \mathbf { \l_tcsc_letter_tl } } } } }
	\cs_if_free:cT { cal \l_tcsc_letter_tl } { \cs_new:cpx { cal \l_tcsc_letter_tl } { \exp_not:N \ensuremath { { \exp_not:N \mathcal { \l_tcsc_letter_tl } } } } }
	\cs_if_free:cT { frak \l_tcsc_letter_tl } { \cs_new:cpx { frak \l_tcsc_letter_tl } { \exp_not:N \ensuremath { { \exp_not:N \mathfrak { \l_tcsc_letter_tl } } } } }
	\cs_if_free:cT { sf \l_tcsc_letter_tl } { \cs_new:cpx { sf \l_tcsc_letter_tl } { \exp_not:N \ensuremath { { \exp_not:N \mathsf { \l_tcsc_letter_tl } } } } }
	\cs_if_free:cT { scr \l_tcsc_letter_tl } { \cs_new:cpx { scr \l_tcsc_letter_tl } { \exp_not:N \ensuremath { { \exp_not:N \mathscr { \l_tcsc_letter_tl } } } } }
}

\int_step_inline:nnn { 1 } { 26 }
{
	\tl_set:Nx \l_tcsc_letter_tl { \int_to_alph:n { #1 } }
	\cs_if_free:cT { bb \l_tcsc_letter_tl }   { \cs_new:cpx { bb \l_tcsc_letter_tl }   { \exp_not:N \ensuremath { { \exp_not:N \mathbb   { \l_tcsc_letter_tl } } } } }
	\cs_if_free:cT { bf \l_tcsc_letter_tl }   { \cs_new:cpx { bf \l_tcsc_letter_tl }   { \exp_not:N \ensuremath { { \exp_not:N \mathbf   { \l_tcsc_letter_tl } } } } }
	\cs_if_free:cT { cal \l_tcsc_letter_tl }  { \cs_new:cpx { cal \l_tcsc_letter_tl }  { \exp_not:N \ensuremath { { \exp_not:N \mathcal  { \l_tcsc_letter_tl } } } } }
	\cs_if_free:cT { frak \l_tcsc_letter_tl } { \cs_new:cpx { frak \l_tcsc_letter_tl } { \exp_not:N \ensuremath { { \exp_not:N \mathfrak { \l_tcsc_letter_tl } } } } }
	\cs_if_free:cT { sf \l_tcsc_letter_tl }   { \cs_new:cpx { sf \l_tcsc_letter_tl }   { \exp_not:N \ensuremath { { \exp_not:N \mathsf   { \l_tcsc_letter_tl } } } } }
	\cs_if_free:cT { scr \l_tcsc_letter_tl }  { \cs_new:cpx { scr \l_tcsc_letter_tl }  { \exp_not:N \ensuremath { { \exp_not:N \mathscr  { \l_tcsc_letter_tl } } } } }
}

\int_step_inline:nnn { 1 } { 26 }
