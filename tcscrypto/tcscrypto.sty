\if@tcscrypto@emphasis
	\RenewDocumentCommand{\emph}{m}{\textsf{#1}}
\fi

\if@tcscrypto@venue
	\setlength{\belowcaptionskip}{-15pt}
	\setlength{\textfloatsep}{10pt plus 1.0pt minus 2.0pt}
\fi

\if@tcscrypto@toc
	\setcounter{tocdepth}{2}
	\@ifpackageloaded{tocbibind}{}{%
		\RequirePackage[nottoc]{tocbibind}%
	}
	\@ifclassloaded{llncs}{%
		\let\tcscrypto@oldmaketitle\maketitle
		\RenewDocumentCommand{\maketitle}{}{%
			\let\tcscrypto@oldaddcontentsline\addcontentsline
			\RenewDocumentCommand{\addcontentsline}{m m m}{}%
			\tcscrypto@oldmaketitle
			\let\addcontentsline\tcscrypto@oldaddcontentsline
		}%
	}{%
		\@ifpackageloaded{setspace}{}{%
			\RequirePackage{setspace}%
		}
		\NewDocumentCommand{\toc}{}{%
			\begin{spacing}{1.05}
				\begin{small}
					\tableofcontents%
				\end{small}
			\end{spacing}
		}
	}%
\fi

