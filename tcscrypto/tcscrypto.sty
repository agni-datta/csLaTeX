%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Game-Hopping References and Code Comments
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\NewDocumentCommand{\newsequenceofgames}{m}{
	\newcounter{#1}
	\setcounter{#1}{-1}
	\@ifundefined{sequencename}{%
		\NewDocumentCommand{\sequencename}{}{#1}%
	}{%
		\RenewDocumentCommand{\sequencename}{}{#1}%
	}
	\ifx\GameID\undefined
		\NewDocumentCommand{\GameID}{}{#1}
	\else
		\RenewDocumentCommand{\GameID}{}{#1}
	\fi
	\ifx\PrevLabel\undefined
		\NewDocumentCommand{\PrevLabel}{}{\GameID.NULL}
	\else
		\RenewDocumentCommand{\PrevLabel}{}{\GameID.NULL}
	\fi
	\ifx\ThisLabel\undefined
		\NewDocumentCommand{\ThisLabel}{}{\GameID.NULL}
	\else
		\RenewDocumentCommand{\ThisLabel}{}{\GameID.NULL}
	\fi
}

\NewDocumentCommand{\nextgame}{m}{
	\let\PrevLabel\ThisLabel
	\RenewDocumentCommand{\ThisLabel}{}{\GameID.#1}
	\refstepcounter{\GameID}\label{\GameID.#1}
	\paragraph{Experiment~$\algostyle{Exp}_\arabic{\GameID}.$}
}
\NewDocumentCommand{\nextgamewithref}{m m}{
	\let\PrevLabel\ThisLabel
	\RenewDocumentCommand{\ThisLabel}{}{\GameID.#1}
	\refstepcounter{\GameID}\label{\GameID.#1}
	\paragraph{Game~\hyperref[#2]{$\algostyle{G}_{\arabic{\GameID}}$}}
}
\NewDocumentCommand{\nextgamewithrefi}{m m m}{
	\let\PrevLabel\ThisLabel
	\RenewDocumentCommand{\ThisLabel}{}{\GameID.#1}
	\refstepcounter{\GameID}\label{\GameID.#1}
	\paragraph{Game~\hyperref[#2]{$\algostyle{G}_{\arabic{\GameID}.#3}$}}
}

\NewDocumentCommand{\gameref}{m}{{\hyperref[\sequencename.#1]{\algostyle{G}_{\ref{\sequencename.#1}}}}}
\NewDocumentCommand{\gamerefi}{m m}{{\hyperref[\sequencename.#1]{\algostyle{G}_{\ref{\sequencename.#1}.#2}}}}
\NewDocumentCommand{\gamerefA}{m}{{\hyperref[\sequencename.#1]{\algostyle{G}^{\advA}_{\ref{\sequencename.#1}}}}}
\NewDocumentCommand{\gamerefAi}{m m}{{\hyperref[\sequencename.#1]{\algostyle{G}^{\advA}_{\ref{\sequencename.#1}.#2}}}}

\NewDocumentCommand{\gamedelta}{m m}{
	\Pr\left[\gamerefA{#1}\Rightarrow 1\right]
	- \Pr\left[\gamerefA{#2}\Rightarrow 1\right]}
\NewDocumentCommand{\gameequal}{m m}{
	\Pr\left[\gamerefA{#1}\Rightarrow 1\right]
	= \Pr\left[\gamerefA{#2}\Rightarrow 1\right]}

\NewDocumentCommand{\gamerefW}{m}{\Pr[\gamerefA{#1} \Rightarrow 1]}
\NewDocumentCommand{\gamerefWi}{m m}{\Pr[\gamerefAi{#1}{#2} \Rightarrow 1]}
\NewDocumentCommand{\codecommentgames}{m m}{\codecomment{$\gameref{#1}$-$\gameref{#2}$}}
\NewDocumentCommand{\codecommentgame}{m}{\codecomment{$\gameref{#1}$}}
\NewDocumentCommand{\timeA}{m}{t_{#1}}

\NewDocumentCommand{\preprocess}{m}{\color{HotPink1}{\blacktriangleright}\:\algostyle{pre:}\:#1}
\NewDocumentCommand{\postprocess}{m}{\color{HotPink2}{\blacktriangleright}\:\algostyle{post:}\:#1}
\NewDocumentCommand{\globalprocess}{m}{\color{OrangeRed1}{\blacktriangleright}\:\algostyle{global:}\:#1}
\NewDocumentCommand{\localprocess}{m}{\color{Chartreuse3}{\blacktriangleright}\:\algostyle{local:}\:#1}

