%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Options
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_new:N \g_tcsc_noemph_bool
\bool_new:N \g_tcsc_small_bool
\bool_new:N \g_tcsc_toc_bool
\bool_new:N \g_tcsc_venue_bool

\keys_define:nn { tcscrypto }
{
	noemph     .bool_gset:N = \g_tcsc_noemph_bool , noemph     .initial:n = false ,
	toc        .bool_gset:N = \g_tcsc_toc_bool    , toc        .initial:n = true  ,
	notoc      .code:n      = { \bool_gset_false:N \g_tcsc_toc_bool } ,
	small      .bool_gset:N = \g_tcsc_small_bool  , small      .initial:n = false ,
	venuestyle .bool_gset:N = \g_tcsc_venue_bool  , venuestyle .initial:n = false ,
	unknown    .code:n      = { \PackageWarning{tcscrypto}{Unknown~option~`#1'~ignored} } ,
}
\ProcessKeysOptions { tcscrypto }

\newif\if@tcscrypto@emphasis \bool_if:NTF \g_tcsc_noemph_bool { \@tcscrypto@emphasistrue } { \@tcscrypto@emphasisfalse }
\newif\if@tcscrypto@small    \bool_if:NTF \g_tcsc_small_bool  { \@tcscrypto@smalltrue    } { \@tcscrypto@smallfalse    }
\newif\if@tcscrypto@toc      \bool_if:NTF \g_tcsc_toc_bool    { \@tcscrypto@toctrue      } { \@tcscrypto@tocfalse      }
\newif\if@tcscrypto@venue    \bool_if:NTF \g_tcsc_venue_bool  { \@tcscrypto@venuetrue    } { \@tcscrypto@venuefalse    }

