\titleformat{\section}
{\normalfont\bfseries\Large}{\thesection}{5pt}{}

\titleformat{\subsection}
{\bfseries\large}{\thesubsection}{7.5pt}{}

\titleformat{\subsubsection}[runin]
{\bfseries\normalsize}{\thesubsubsection.}{0.75em}{}[.\ ]

\titlecontents{section}
[6.5em]{}
{\itshape\small\contentslabel{2.3em}}
{\itshape\small}
{\hfill\textit{\thecontentspage}}
[\vspace*{2pt}]

\@ifundefined{allcapsspacing}{}{\RenewDocumentCommand{\allcapsspacing}{m}{\textls[250]{#1}}}
\@ifundefined{allcaps}{}{\RenewDocumentCommand{\allcaps}{m}{\textls[250]{\MakeTextUppercase{#1}}}}
\@ifundefined{smallcapsspacing}{}{\RenewDocumentCommand{\smallcapsspacing}{m}{\textls[175]{#1}}}
\@ifundefined{smallcaps}{}{\RenewDocumentCommand{\smallcaps}{m}{\smallcapsspacing{\scshape\MakeTextLowercase{#1}}}}
\@ifundefined{textsmallcaps}{}{\RenewDocumentCommand{\textsc}{m}{\smallcapsspacing{\textsmallcaps{#1}}}}

\RenewDocumentCommand{\maketitlepage}{}{%
    \begingroup
    \setlength{\parindent}{0pt}
    {\LARGE\textsc{\@author}\par}
    \vspace{1.75in}{\HUGE\itshape\@title\par}
    \vspace{0.5in}{\large\textsf{\smallcaps{\@date}}\par}
    \vfill{\large\textit{\@publisher}\par}
    \thispagestyle{empty}
    \endgroup
}

