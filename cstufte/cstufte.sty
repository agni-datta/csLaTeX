%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Typography and microtype
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage[final,protrusion=true,expansion=true]{microtype}
\microtypesetup{activate=true,final,protrusion=true,expansion=true,stretch=30,factor=1500}
\UseMicrotypeSet[protrusion]{basicmath}
\UseMicrotypeSet[expansion]{alltext}
\SetExpansion{encoding=*,family=*}{stretch=30,shrink=30,step=1}
\SetProtrusion{encoding=*,family=*}{period={,50},comma={,40},colon={,30},semicolon={,30}}
\DisableLigatures[f]{encoding=T1,family=tt*}
\SetTracking{encoding=*,shape=sc}{40}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Fonts
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\ifPDFTeX
    \ifdefstring{\cstf@font}{baskerville}{%
        \RequirePackage[proportional,tabular]{Baskervaldx}%
        \RequirePackage[baskervaldx,varbb]{newtxmath}%
        \RequirePackage{biolinum}%
    }{%
        \RequirePackage[nofligatures,oldstylenums]{kpfonts}%
    }
\else
    \RequirePackage{fontspec}
    \ifdefstring{\cstf@font}{baskerville}{%
        \setmainfont{Baskervaldx}[
            Ligatures         = TeX,
            SmallCapsFeatures = {RawFeature=+smcp},
            RawFeature        = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
        ]%
        \setsansfont{Libertinus Sans}[
            Scale             = MatchUppercase,
            Ligatures         = TeX,
            SmallCapsFeatures = {RawFeature=+smcp},
            RawFeature        = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
        ]%
        \setmonofont{Anonymous Pro}[
            Scale      = MatchLowercase,
            Ligatures  = TeX,
            RawFeature = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
        ]%
    }{%
        \RequirePackage[nosf,noDcommand,fakedscripts]{kpfonts-otf}%
        \setsansfont{Libertinus Sans}[
            Scale             = MatchUppercase,
            Ligatures         = TeX,
            RawFeature        = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum},
            SmallCapsFeatures = {Letters=SmallCaps}
        ]%
        \setmonofont{Anonymous Pro}[
            Scale      = MatchLowercase,
            Ligatures  = TeX,
            RawFeature = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
        ]%
    }
\fi

