%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Options
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_new:N \g_cstf_colorful_bool
\bool_new:N \g_cstf_draft_bool
\tl_new:N   \g_cstf_rulerwidth_tl
\tl_new:N   \g_cstf_framecolor_tl
\tl_new:N   \g_cstf_font_tl
\tl_new:N   \g_cstf_backcolor_tl

\keys_define:nn { cstufte }
{
    colorful    .bool_gset:N = \g_cstf_colorful_bool ,
    colorful    .initial:n   = false ,
    draft       .bool_gset:N = \g_cstf_draft_bool ,
    draft       .initial:n   = false ,
    rulerwidth  .tl_gset:N   = \g_cstf_rulerwidth_tl ,
    rulerwidth  .initial:n   = 2pt ,
    framecolor  .tl_gset:N   = \g_cstf_framecolor_tl ,
    framecolor  .initial:n   = black ,
    font        .tl_gset:N   = \g_cstf_font_tl ,
    font        .initial:n   = kpfonts ,
    backcolor   .tl_gset:N   = \g_cstf_backcolor_tl ,
    backcolor   .initial:n   = white ,
    unknown     .code:n      = { \PackageWarning{cstufte}{Unknown~option~`#1'~ignored} } ,
}
\ProcessKeysOptions { cstufte }

\tl_set_eq:cN { cstf@rulerwidth  } \g_cstf_rulerwidth_tl
\tl_set_eq:cN { cstf@framecolor  } \g_cstf_framecolor_tl
\tl_set_eq:cN { cstf@font        } \g_cstf_font_tl
\tl_set_eq:cN { cstf@backcolor   } \g_cstf_backcolor_tl

\newif\ifcstf@colorful  \bool_if:NTF \g_cstf_colorful_bool { \cstf@colorfultrue } { \cstf@colorfulfalse }
\newif\ifcstf@draft     \bool_if:NTF \g_cstf_draft_bool    { \cstf@drafttrue    } { \cstf@draftfalse    }

\ExplSyntaxOff

