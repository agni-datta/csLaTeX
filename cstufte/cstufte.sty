\declaretheoremstyle[
    headfont      = \scshape,
    notefont      = \normalfont\scshape,
    bodyfont      = \normalfont,
    spaceabove    = 3pt,
    spacebelow    = 3pt,
    headpunct     = {.},
    postheadspace = 0.5em
]{cstf@theoremlike}

\declaretheoremstyle[
    headfont      = \scshape,
    notefont      = \normalfont\scshape,
    bodyfont      = \normalfont,
    spaceabove    = 3pt,
    spacebelow    = 3pt,
    headpunct     = {.},
    postheadspace = 0.5em
]{cstf@definitionlike}

\declaretheoremstyle[
    headfont      = \normalfont\scshape,
    bodyfont      = \normalfont,
    spaceabove    = 3pt,
    spacebelow    = 3pt,
    headpunct     = {.},
    postheadspace = 0.5em
]{cstf@remarklike}

\declaretheoremstyle[
    headfont      = \normalfont\sffamily,
    bodyfont      = \normalfont,
    spaceabove    = 3pt,
    spacebelow    = 3pt,
    headpunct     = {.},
    postheadspace = 0.5em
]{cstf@highlightlike}

\declaretheoremstyle[
    headfont      = \itshape,
    bodyfont      = \normalfont,
    spaceabove    = 5pt,
    spacebelow    = 5pt,
    headpunct     = {.},
    postheadspace = 0.5em,
    qed           = \ensuremath{\scriptstyle\square}
]{cstf@proofstyle}

\declaretheorem
[
    name         = Theorem ,
    style        = cstf@theoremlike ,
    numberwithin = section
]{ theorem }

\NewDocumentCommand{\cstf@declaretheoremfamily}{mm}{%
