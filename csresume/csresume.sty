%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Package Options
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\ExplSyntaxOn

\str_new:N  \gcsrsfontstr
\bool_new:N \gcsrsallowbreaksbool

\str_gset:Nn \gcsrsfontstr { gfsdidot }
\bool_gset_false:N \gcsrsallowbreaksbool

\msg_new:nnn { csresume } { unknown-option }
{ Unknown~option~`#1'~ignored. }

\keys_define:nn { csresume }
{
	font        .str_gset:N  = \gcsrsfontstr ,
	font        .initial:n   = gfsdidot ,
	allowbreaks .bool_gset:N = \gcsrsallowbreaksbool ,
	allowbreaks .default:n   = true ,
	gfsdidot    .code:n      = { \str_gset:Nn \gcsrsfontstr { gfsdidot    } } ,
	libertinus  .code:n      = { \str_gset:Nn \gcsrsfontstr { libertinus  } } ,
	euler       .code:n      = { \str_gset:Nn \gcsrsfontstr { euler       } } ,
	baskerville .code:n      = { \str_gset:Nn \gcsrsfontstr { baskerville } } ,
	unknown     .code:n      = { \msg_warning:nnn { csresume } { unknown-option } {#1} } ,
}

\cs_new_protected:Npn \csrsprocessoption
{
	\keys_set:no { csresume } { \CurrentOption }
}

\ExplSyntaxOff

\DeclareOption*{\csrsprocessoption}
\ProcessOptions\relax

\newif\ifcsrsbaskerville
\newif\ifcsrseuler
\newif\ifcsrsgfsdidot
\newif\ifcsrslibertinus
\newif\ifcsrsallowbreaks

\ExplSyntaxOn
\str_if_eq:VnT \gcsrsfontstr { baskerville }
{ \csrsbaskervilletrue }
\str_if_eq:VnT \gcsrsfontstr { euler }
{ \csrseulertrue }
\str_if_eq:VnT \gcsrsfontstr { gfsdidot }
{ \csrsgfsdidottrue }
\str_if_eq:VnT \gcsrsfontstr { libertinus }
{ \csrslibertinustrue }
\bool_if:NT \gcsrsallowbreaksbool
{ \csrsallowbreakstrue }
\ExplSyntaxOff

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Core Packages
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage[
	2.0,
	compress,
	objcompress
]{bxpdfver}
\RequirePackage{babel}
\RequirePackage[
	autostyle = true,
	csdisplay = true
]{csquotes}
\RequirePackage{etoolbox}
\RequirePackage{graphicx}
\RequirePackage{iftex}
\RequirePackage[
	dvipsnames,
	table,
	x11names
]{xcolor}

\colorlet{accentcolor}{DeepSkyBlue4}
\colorlet{secondaccentcolor}{accentcolor!82!black}
\colorlet{thirdaccentcolor}{accentcolor!70!black}
\colorlet{fourthaccentcolor}{accentcolor!58!black}
\colorlet{csrsink}{accentcolor!38!black}
\colorlet{csrsmuted}{accentcolor!52!black}
\colorlet{csrsrule}{accentcolor!76!black}
\colorlet{csrssoftrule}{accentcolor!68!black}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Typography
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage[
	final,
	protrusion = true,
	expansion  = true
]{microtype}

\microtypesetup{
	activate   = true,
	final      = true,
	protrusion = true,
	expansion  = true,
	stretch    = 50,
	factor     = 1500
}

\UseMicrotypeSet[protrusion]{basicmath}
\UseMicrotypeSet[expansion]{alltext}
\SetExpansion{
	encoding = *,
	family   = *
}{
	stretch = 50,
	shrink  = 50,
	step    = 1
}
\SetProtrusion{
	encoding = *,
	family   = *
}{
	. = {,50},
	, = {,40},
	: = {,30},
	; = {,30}
}

\emergencystretch=2em

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Fonts
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\ifPDFTeX
	\RequirePackage[
		proportional,
		tabular
	]{Baskervaldx}
	\RequirePackage{biolinum}
	\RequirePackage[
		baskervaldx,
		varbb
	]{newtxmath}
	\RequirePackage[
		cal = txupr,
		bb  = stix,
		scr = dutchcal
	]{mathalpha}
\else
	\RequirePackage{fontspec}
	\RequirePackage{unicode-math}

	\NewDocumentCommand{\csrssetmonofont}{}{%
		\setmonofont{AnonymousPro-Regular.ttf}[
			BoldFont       = AnonymousPro-Bold.ttf,
			ItalicFont     = AnonymousPro-Italic.ttf,
			BoldItalicFont = AnonymousPro-BoldItalic.ttf,
			Scale          = MatchLowercase,
			Ligatures      = TeX,
			RawFeature     = { +calt,+case,+kern,+mark,+mkmk,+liga,+lnum,+tnum }
		]%
	}
	\NewDocumentCommand{\csrssetmonomathfont}{}{%
		\setmathfont{AnonymousPro-Regular.ttf}[
			Scale      = MatchUppercase,
			range      = { tt/{latin,Latin,num} },
			RawFeature = { +calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum }
		]%
	}

	\setsansfont{Libertinus Sans}[
		Scale             = MatchUppercase,
		Ligatures         = TeX,
		SmallCapsFeatures = { RawFeature = +smcp },
		RawFeature        = { +calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum }
	]
	\csrssetmonofont

	\ifcsrsbaskerville
		\setmainfont{Baskervaldx}[
			Ligatures         = TeX,
			SmallCapsFeatures = { RawFeature = +smcp },
			RawFeature        = { +calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum }
		]
		\setmathfont{KPMath-Regular}[
			Scale = MatchUppercase,
			AutoFakeBold,
			AutoFakeSlant
		]
		\setmathfont{Baskervaldx-Reg}[
			Scale      = MatchUppercase,
			range      = { up/{latin,Latin,num} },
			Ligatures  = TeX,
			RawFeature = { +calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum }
		]
		\setmathfont{Baskervaldx-Ita}[
			Scale      = MatchUppercase,
			range      = { it/{latin,Latin} },
			Ligatures  = TeX,
			RawFeature = { +calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum }
		]
		\setmathfont{Libertinus Sans}[
			Scale      = MatchUppercase,
			range      = { sfup/{latin,Latin,num}, sfit/{latin,Latin} },
			Ligatures  = TeX,
			RawFeature = { +calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum }
		]
		\csrssetmonomathfont
	\fi

	\ifcsrseuler
		\RequirePackage[euler]{fontsetup}
		\csrssetmonofont
		\csrssetmonomathfont
		\defaultfontfeatures{
			SmallCapsFeatures = { RawFeature = +smcp,+lnum,+tnum },
			RawFeature        = { +calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum }
		}
	\fi

	\ifcsrsgfsdidot
		\RequirePackage[gfsdidot]{fontsetup}
		\setsansfont{Libertinus Sans}[
			Scale      = MatchUppercase,
			Ligatures  = TeX,
			RawFeature = { +calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum }
		]
		\csrssetmonofont
	\fi

	\ifcsrslibertinus
		\setmainfont{Libertinus Serif}[
			Ligatures         = TeX,
			SmallCapsFeatures = { RawFeature = +smcp },
			RawFeature        = { +calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum }
		]
		\setsansfont{Libertinus Sans}[
			Scale             = MatchUppercase,
			Ligatures         = TeX,
			SmallCapsFeatures = { RawFeature = +smcp },
			RawFeature        = { +calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum }
		]
		\csrssetmonofont
		\setmathfont{KPMath-Regular}[
			AutoFakeBold,
			AutoFakeSlant,
			Scale      = MatchUppercase,
			RawFeature = { +calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum }
		]
		\setmathfont{LibertinusSerif-Regular}[
			Scale      = MatchUppercase,
			range      = { up/{latin,Latin,num} },
			Ligatures  = TeX,
			RawFeature = { +calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum }
		]
		\setmathfont{LibertinusSerif-Italic}[
			Scale      = MatchUppercase,
			range      = { it/{latin,Latin} },
			Ligatures  = TeX,
			RawFeature = { +calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum }
		]
		\setmathfont{Libertinus Sans}[
			Scale      = MatchUppercase,
			range      = { sfup/{latin,Latin,num}, sfit/{latin,Latin} },
			Ligatures  = TeX,
			RawFeature = { +calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum }
		]
		\csrssetmonomathfont
	\fi
\fi

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Page Layout
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage[margin=1in]{geometry}
\geometry{
	paper          = letterpaper,
	top            = 2cm,
	bottom         = 2cm,
	left           = 4cm,
	right          = 2cm,
	heightrounded,
	marginparwidth = 3.5cm,
	marginparsep   = 0.5cm,
	headheight     = 0.75cm,
	headsep        = 0.75cm,
	footskip       = 1cm
}

\RequirePackage{setspace}
\setstretch{1.05}
\setlength{\parindent}{0pt}
\setcounter{secnumdepth}{0}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Margin Labels
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{marginnote}
\reversemarginpar
\RenewDocumentCommand{\raggedleftmarginnote}{}{}
\setlength{\marginparsep}{-10pt}
\setlength{\marginparpush}{0.45em}

\NewDocumentCommand{\years}{m}{%
	\marginnote{\footnotesize\sffamily\scshape\textls[60]{\textcolor{fourthaccentcolor}{#1}}}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Section Headings
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{titlesec}

\NewDocumentCommand{\csrsspacedsection}{m}{%
	\textls[170]{\MakeUppercase{#1}}%
}
\NewDocumentCommand{\csrsspacedsubsection}{m}{%
	\textls[135]{\MakeUppercase{#1}}%
}
\NewDocumentCommand{\csrsspacedsubsubsection}{m}{%
	\textls[110]{\MakeUppercase{#1}}%
}

\titleformat{\section}
{\large\sffamily\mdseries\color{accentcolor}}
{}
{0em}
{\csrsspacedsection}
[\color{secondaccentcolor}\titlerule]

\titleformat{\subsection}
{\normalsize\sffamily\mdseries\color{accentcolor}}
{}
{0em}
{\csrsspacedsubsection}
[\color{csrsrule}\titlerule]

\titleformat{\subsubsection}
{\mdseries\sffamily\normalsize\color{csrsink}}
{}
{0em}
{\csrsspacedsubsubsection}

\titlespacing*{\section}
{0pt}
{2.9ex plus .5ex minus .2ex}
{1.85ex plus .3ex}

\titlespacing*{\subsection}
{0pt}
{2.45ex plus .3ex minus .1ex}
{1.75ex plus .2ex}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Lists and Columns
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage{enumitem}
\setlist{nosep,noitemsep}
\setlist[itemize]{label=\textcolor{accentcolor}{\textbullet}}

\RequirePackage{multicol}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Bibliography
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage[
	hyperref      = true,
	defernumbers  = true,
	bibstyle      = alphabetic,
	maxalphanames = 4,
	minalphanames = 3,
	maxnames      = 999,
	sorting       = ydnt,
	giveninits    = false,
	backend       = biber
]{biblatex}

\DeclareFieldFormat{marginlabel}{#1}
\DeclareFieldFormat{labelalpha}{}
\DeclareFieldFormat{labelalphawidth}{}
\setlength{\biblabelsep}{0pt}
\setlength{\labelwidth}{0pt}
\setlength{\bibitemsep}{0.45em}
\setlength{\bibparsep}{0pt}
\DeclareNameAlias{default}{given-family}

\DeclareFieldFormat[
	article,
	inproceedings,
	incollection,
	inbook,
	thesis
]{title}{\textit{#1}\isdot}
\DeclareFieldFormat[unpublished]{title}{\textit{#1}\isdot}
\DeclareFieldFormat[unpublished]{titlecase}{\textit{#1}\isdot}

\renewbibmacro*{begentry}{%
	\years{[\printfield[marginlabel]{labelalpha}]}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Hyperlinks and PDF Metadata
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage[bookmarks,colorlinks,breaklinks]{hyperref}
\hypersetup{
	bookmarksnumbered = true,
	breaklinks        = true,
	colorlinks        = true,
	frenchlinks       = true,
	pdfencoding       = auto,
	pdfpagelayout     = SinglePage,
	pdfstartview      = FitH,
	unicode           = true,
	linkcolor         = accentcolor,
	citecolor         = accentcolor,
	filecolor         = accentcolor,
	urlcolor          = accentcolor,
	pdftitle          = {Curriculum Vitae},
	pdfauthor         = {}
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Public CV Commands
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\NewDocumentCommand{\csrscontactlabel}{m}{%
	\textcolor{fourthaccentcolor}{#1}%
}

\NewDocumentCommand{\csrscontactseparator}{}{%
	\quad \textcolor{thirdaccentcolor}{|} \quad
}

\NewDocumentCommand{\contactblock}{m m m m m m m}{%
	{\huge\sffamily\mdseries\color{accentcolor}\textls[170]{#1}\par}%
	\vspace{0.55em}%
	{\color{secondaccentcolor}\hrule height 0.45pt\par}%
	\vspace{0.85em}%
	{\textit{#2}}\par
	\vspace{0.25em}%
	#3\par
	\vspace{0.45em}%
	{%
		\csrscontactlabel{Email:}~~\texttt{\href{mailto:#4}{#4}}%
		\csrscontactseparator
		\csrscontactlabel{Website:}~~\texttt{\href{https://#5}{#5}}\par
		\csrscontactlabel{Scholar:}~~\texttt{\href{https://scholar.google.com/citations?user=#6}{#6}}%
		\csrscontactseparator
		\csrscontactlabel{DBLP:}~~\texttt{\href{https://dblp.org/pid/#7}{#7}}%
	}%
	\vspace{0.85em}%
	{\color{csrssoftrule}\hrule height 0.35pt\par}%
}

\NewDocumentCommand{\details}{m m m m}{%
	\years{#1}%
	{\itshape #2},\ {#3}\\[2pt]%
	{#4}\par\addvspace{0.62em}%
	\ifcsrsallowbreaks\pagebreak[0]\fi
}

\NewDocumentCommand{\columndetails}{m m m}{%
	\years{#1}%
	{\itshape #2}%
	\hfill #3%
	\par\addvspace{0.36em}%
	\ifcsrsallowbreaks\pagebreak[0]\fi
}

\NewDocumentCommand{\referals}{m m m m m m m m}{%
	\noindent\small
	\begin{minipage}{\linewidth}
		{#1~\color{csrsink}#2~{\scshape#3}}\par
		\textit{#4}\par
		#5\par
		#6\par
		\href{mailto:#7}{\texttt{#7}}\par
		\href{https://#8}{\texttt{#8}}
	\end{minipage}%
	\par\vspace{1.5em}%
}

\NewDocumentCommand{\finishcv}{m m}{%
	\par\vfill
	\begin{center}
		\footnotesize\sffamily\color{csrsmuted}%
		{%
			Updated~#1%
			\hspace{0.5em}{\color{secondaccentcolor}\raisebox{0.15ex}{\tiny\textbullet}}\hspace{0.5em}%
			\href{#2}{\texttt{#2}}%
		}%
	\end{center}%
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Public CV Environments
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\NewDocumentEnvironment{refcolumns}{}
{\begin{multicols}{2}}
{\end{multicols}}

\NewDocumentEnvironment{ditemize}{}
{\begin{multicols}{2}\begin{itemize}[nosep,leftmargin=*]}
{\end{itemize}\end{multicols}}

\endinput
