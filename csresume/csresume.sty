\NeedsTeXFormat{LaTeX2e}[2022-06-01]
\ProvidesPackage{csresume}[2026/04/14 v4.1 CV and resume templating package]

\RequirePackage{etoolbox}
\RequirePackage{expl3}
\RequirePackage{iftex}
\RequirePackage{xparse}

\ExplSyntaxOn

\str_new:N  \g__csrs_font_str
\bool_new:N \g__csrs_allowbreaks_bool
\str_gset:Nn \g__csrs_font_str { gfsdidot }
\bool_gset_false:N \g__csrs_allowbreaks_bool

\keys_define:nn { csresume }
{
    font        .str_gset:N  = \g__csrs_font_str ,
    font        .initial:n   = gfsdidot ,
    allowbreaks .bool_gset:N = \g__csrs_allowbreaks_bool ,
    allowbreaks .default:n   = true ,
    gfsdidot    .code:n = { \str_gset:Nn \g__csrs_font_str { gfsdidot    } } ,
    libertinus  .code:n = { \str_gset:Nn \g__csrs_font_str { libertinus  } } ,
    euler       .code:n = { \str_gset:Nn \g__csrs_font_str { euler       } } ,
    baskerville .code:n = { \str_gset:Nn \g__csrs_font_str { baskerville } } ,
    unknown     .code:n = { \msg_warning:nnn { csresume } { unknown-option } {#1} } ,
}

\msg_new:nnn { csresume } { unknown-option } { Unknown~option~`#1'~ignored. }

\cs_new_protected:Npn \csrs@process@option {
    \keys_set:no { csresume } { \CurrentOption }
}

\ExplSyntaxOff

\DeclareOption*{\csrs@process@option}
\ProcessOptions\relax

\newif\ifcsrs@baskerville
\newif\ifcsrs@allowbreaks

\ExplSyntaxOn
\str_if_eq:VnT \g__csrs_font_str { baskerville } { \csrs@baskervilletrue }
\bool_if:NT \g__csrs_allowbreaks_bool { \csrs@allowbreakstrue }
\cs_gset:Npx \csrs@fontname { \g__csrs_font_str }
\ExplSyntaxOff

\RequirePackage[
    2.0,
    compress,
    objcompress
]{bxpdfver}
\RequirePackage[english]{babel}
\RequirePackage[
    autostyle = true,
    csdisplay = true
]{csquotes}
\RequirePackage{graphicx}
\RequirePackage[
    dvipsnames,
    table,
    x11names
]{xcolor}

\RequirePackage[
    final,
    protrusion=true,
    expansion=true
]{microtype}
\microtypesetup{
    activate   = true,
    final      = true,
    protrusion = true,
    expansion  = true,
    stretch    = 50,
    factor     = 1250
}
\UseMicrotypeSet[protrusion]{basicmath}
\UseMicrotypeSet[expansion]{alltext}
\SetExpansion{
    encoding=*,
    family=*
}{
    stretch=50,
    shrink=50,
    step=1
}
\SetProtrusion{
    encoding=*,
    family=*
}{
    period={,50},
    comma={,40},
    colon={,30},
    semicolon={,30}
}
\emergencystretch=2em

\ifPDFTeX
    \RequirePackage[T1]{fontenc}
    \RequirePackage[
        proportional,
        tabular
    ]{Baskervaldx}
    \RequirePackage{biolinum}
    \RequirePackage[
        baskervaldx,
        varbb
    ]{newtxmath}
    \RequirePackage[
        cal=txupr,
        bb=stix,
        scr=dutchcal
    ]{mathalpha}
\else
    \ifcsrs@baskerville
        \RequirePackage{fontspec}
        \RequirePackage[warnings-off={mathtools-colon,mathtools-overbracket}]{unicode-math}
        \setmainfont{Baskervaldx}[
            Ligatures           = TeX,
            SmallCapsFeatures   = {RawFeature = +smcp},
            RawFeature          = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
        ]
        \setsansfont{Libertinus Sans}[
            Scale               = MatchUppercase,
            Ligatures           = TeX,
            SmallCapsFeatures   = {RawFeature = +smcp},
            RawFeature          = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
        ]
        \setmonofont{Noto Sans Mono}[
            Scale               = MatchLowercase,
            Ligatures           = TeX
        ]

        \setmathfont{KPMath-Regular}[
            Scale               = MatchUppercase,
            AutoFakeBold,
            AutoFakeSlant
        ]

        \setmathfont{Baskervaldx-Reg}[
            Scale               = MatchUppercase,
            range               = {up/{latin,Latin,num}},
            Ligatures           = TeX,
            RawFeature          = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
        ]

        \setmathfont{Baskervaldx-Ita}[
            Scale               = MatchUppercase,
            range               = {it/{latin,Latin}},
            Ligatures           = TeX,
            RawFeature          = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
        ]

        \setmathfont{Libertinus Sans}[
            Scale               = MatchUppercase,
            range               = {sfup/{latin,Latin,num}, sfit/{latin,Latin}},
            Ligatures           = TeX,
            RawFeature          = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
        ]

        \setmathfont{Noto Sans Mono}[
            Scale               = MatchUppercase,
            range               = {tt/{latin,Latin,num}},
            RawFeature          = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
        ]
    \else
        \expandafter\RequirePackage\expandafter[\csrs@fontname]{fontsetup}
        \setsansfont{Libertinus Sans}[
            Scale               = MatchUppercase,
            Ligatures           = TeX,
            SmallCapsFeatures   = {RawFeature=+smcp},
            RawFeature          = {+calt,+case,+kern,+liga,+mark,+mkmk,+lnum,+tnum}
        ]
    \fi
\fi

\RequirePackage{geometry}
\geometry{
