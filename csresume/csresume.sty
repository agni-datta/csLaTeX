    top            = 2cm,
    bottom         = 2cm,
    left           = 4cm,
    right          = 2cm,
    heightrounded,
    marginparwidth = 3.5cm,
    marginparsep   = 0.5cm,
    headheight     = 0.75cm,
    headsep        = 0.75cm,
    footskip       = 1cm,
}

\RequirePackage{setspace}
\setstretch{1.10}
\setlength{\parindent}{0pt}
\setcounter{secnumdepth}{0}

\RequirePackage{marginnote}
\reversemarginpar
\renewcommand*{\raggedleftmarginnote}{}
\setlength{\marginparsep}{-10pt}

\newcommand{\years}[1]{\marginnote{\footnotesize\scshape#1}}

\RequirePackage{titlesec}
\titleformat{\section}{\Large\color{black!75}\scshape}{}{0em}{}[\titlerule]
\titleformat{\subsection}{\large\color{black!75}\scshape}{}{0em}{}[\titlerule]
\titleformat{\subsubsection}{\mdseries\scshape\sffamily\normalsize\color{black!75}}{}{0em}{}
\titlespacing*{\section}{0pt}{2ex plus .3ex minus .2ex}{1.5ex plus .2ex}
\titlespacing*{\subsection}{0pt}{1.5ex plus .2ex minus .1ex}{1.2ex plus .1ex}

\RequirePackage{enumitem}
\setlist{nosep,noitemsep}
\setlist[itemize]{label=\textcolor{black!75}{\textbullet}}

\RequirePackage{multicol}

\RequirePackage[
    hyperref      = true,
    defernumbers  = true,
    bibstyle      = alphabetic,
    maxalphanames = 4,
    minalphanames = 3,
    maxnames      = 999,
    sorting       = ydnt,
    giveninits    = false,
    backend       = biber,
]{biblatex}

\DeclareFieldFormat{marginlabel}{#1}
\DeclareFieldFormat{labelalpha}{}
\DeclareFieldFormat{labelalphawidth}{}
\setlength{\biblabelsep}{0pt}
\setlength{\labelwidth}{0pt}

\DeclareNameAlias{default}{given-family}

\DeclareFieldFormat[
    article,
    inproceedings,
    incollection,
    inbook,
    thesis,
    unpublished
]{title}{\textit{#1}\isdot}

\renewbibmacro*{begentry}{%
    \years{[\printfield[marginlabel]{labelalpha}]}%
}

