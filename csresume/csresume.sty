\hypersetup{
    bookmarksnumbered = true,
    breaklinks        = true,
    colorlinks        = true,
    frenchlinks       = true,
    pdfencoding       = auto,
    pdfpagelayout     = SinglePage,
    pdfstartview      = FitH,
    unicode           = true,
    linkcolor         = MidnightBlue,
    citecolor         = MidnightBlue,
    filecolor         = MidnightBlue,
    urlcolor          = MidnightBlue,
    pdftitle          = {Curriculum Vitae},
    pdfauthor         = {},
}

\NewDocumentCommand{\contactblock}{m m m m m m m}{%
    {\color{black!75}\huge\scshape#1\bigskip\hrule\par}%
    \vspace{1em}%
    \textsc{#2}\\%
    #3\par
    Email:~\texttt{\href{mailto:#4}{#4}}~|~%
    Website:~\texttt{\href{https://#5}{#5}}\par
    Scholar:~\texttt{\href{https://scholar.google.com/citations?user=#6}{#6}}~|~%
    DBLP:~\texttt{\href{https://dblp.org/pid/#7}{#7}}%
    {\color{black!75}\vspace{1em}\hrule\par}%
}

\NewDocumentCommand{\details}{m m m m}{%
    \years{#1}%
    {\itshape#2},\ {#3}\\[2pt]%
    {#4}\par\smallskip
}

\NewDocumentCommand{\columndetails}{m m m}{%
    \years{#1}%
    {\itshape#2}%
    \hfill#3%
}

\NewDocumentCommand{\referals}{m m m m m m}{%
    \noindent
    \begin{minipage}{\linewidth}
        \textbf{#1}\par
        \textit{#2}\par
        #3\par
        #4\par
        \href{mailto:#5}{\texttt{#5}}\par
        \href{https://#6}{\texttt{#6}}
    \end{minipage}%
    \par\vspace{1.5em}%
}

\NewDocumentCommand{\finishcv}{m m}{%
    \par\vfill
    \begin{center}
        \footnotesize\sffamily
        \textcolor{gray}{%
            \textsc{Updated on~#1}~~{\raisebox{-0.5pt}{\textbullet}}~~%
            \href{https://#2}{\textnormal{\texttt{#2}}}%
        }%
    \end{center}%
}

\newenvironment{refcolumns}
{\begin{multicols}{2}\small}
{\end{multicols}}

\newenvironment{ditemize}
{\begin{multicols}{2}\begin{itemize}[nosep,leftmargin=*]}
{\end{itemize}\end{multicols}}

\ifcsrs@allowbreaks
    \AtEndPreamble{%
        \appto{\details}{\pagebreak[0]}%
        \appto{\columndetails}{\pagebreak[0]}%
    }%
\fi

