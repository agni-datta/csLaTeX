  pdfencoding        = auto,
  pdfpagelabels      = true,
  pdfpagelayout      = SinglePage,
  pdfstartview       = FitH,
  pdfusetitle,
  unicode            = true,
  urlcolor           = Blue4
]{hyperref}

\pdfstringdefDisableCommands{%
\def\S{\textsection}%
\def\langle{<}\def\rangle{>}%
\def\lceil{[}\def\rceil{]}%
\def\left{}\def\right{}%
\def\lfloor{[}\def\rfloor{]}%
\def\mathbb#1{#1}%
\def\mathbf#1{#1}%
\def\mathcal#1{#1}%
\def\mathfrak#1{#1}%
\def\mathrm#1{#1}%
\def\mathscr#1{#1}%
\def\mathsf#1{#1}%
\def\mathtt#1{#1}%
\def\operatorname#1{#1}%
\def\text#1{#1}%
\def\var#1{#1}%
}

\renewcommand*{\backref}[1]{}
\renewcommand*{\backrefalt}[4]{%
  \ifcase #1\or (Cited on p.~#2).
  \else (Cited on pp.~#2).
  \fi
}

\ifeudoxlayout
