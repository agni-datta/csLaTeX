%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Paragraph headings
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\newif\ifedxhaspunct

\def\edxcheckpunct{}

\def\edx@checkdot#1.\edxsep#2\edxend{\edxcheckpunct{#2}}
\def\edx@checkquestion#1?\edxsep#2\edxend{\edxcheckpunct{#2}}
\def\edx@checkexclam#1!\edxsep#2\edxend{\edxcheckpunct{#2}}
\def\edx@checkcolon#1:\edxsep#2\edxend{\edxcheckpunct{#2}}

\NewDocumentCommand{\edxappendpunct}{m}{%
    \edxhaspunctfalse
    \edx@checkdot#1\edxsep.\edxsep\edxend
    \edx@checkquestion#1\edxsep?\edxsep\edxend
    \edx@checkexclam#1\edxsep!\edxsep\edxend
    \edx@checkcolon#1\edxsep:\edxsep\edxend
    #1\ifedxhaspunct\else.\fi
}

\NewDocumentCommand{\edxeatnewline}{}{%
    \begingroup\catcode13=10\endgroup
}

\NewDocumentCommand{\parhead}{m}{%
    \smallskip\noindent
    \textbf{\boldmath\ignorespaces\edxappendpunct{#1}}%
    \hskip 0.30em
    \ignorespaces
}

\NewDocumentCommand{\subparhead}{m}{%
    \smallskip\noindent
    \textsc{\ignorespaces\edxappendpunct{#1}}%
    \hskip 0.30em
    \ignorespaces
}

\AtBeginDocument{%
    \RenewDocumentCommand{\paragraph}  {m}{\parhead{#1}}%
    \RenewDocumentCommand{\subparagraph}{m}{\subparhead{#1}}%
}

