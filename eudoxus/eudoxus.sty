}
\zcRefTypeSetup{subsubsection}{
  Name-sg = \textsection,
  name-sg = \textsection,
  Name-pl = \textsection\textsection,
  name-pl = \textsection\textsection
}

\NewDocumentCommand{\Cref}{O{}m}{\zcref[S,#1]{#2}}
\let\cref\zcref
\let\crefrange\zcrefrange

