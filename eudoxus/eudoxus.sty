\ExplSyntaxOn

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Options
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\bool_new:N \g_eudox_math_bool
\bool_new:N \g_eudox_theorems_bool
\bool_new:N \g_eudox_tcs_bool
\bool_new:N \g_eudox_layout_bool

\keys_define:nn { eudoxus }
{
    nomath     .code:n  = { \bool_gset_false:N \g_eudox_math_bool
            \bool_gset_false:N \g_eudox_theorems_bool
            \bool_gset_false:N \g_eudox_tcs_bool } ,
    notheorems .code:n  = { \bool_gset_false:N \g_eudox_theorems_bool } ,
    tcs        .code:n  = { \bool_gset_true:N  \g_eudox_tcs_bool } ,
    notcs      .code:n  = { \bool_gset_false:N \g_eudox_tcs_bool } ,
    nolayout   .code:n  = { \bool_gset_false:N \g_eudox_layout_bool } ,
    unknown    .code:n  = { \PackageWarning{eudoxus}{Unknown~option~`#1'} } ,
}

\bool_gset_true:N  \g_eudox_math_bool
\bool_gset_true:N  \g_eudox_theorems_bool
\bool_gset_false:N \g_eudox_tcs_bool
\bool_gset_true:N  \g_eudox_layout_bool

\ProcessKeysOptions { eudoxus }

\newif\ifeudoxmath     \bool_if:NTF \g_eudox_math_bool     { \eudoxmathtrue     } { \eudoxmathfalse     }
\newif\ifeudoxtheorems \bool_if:NTF \g_eudox_theorems_bool { \eudoxtheoremstrue } { \eudoxtheoremsfalse }
\newif\ifeudoxtcs      \bool_if:NTF \g_eudox_tcs_bool      { \eudoxtcstrue      } { \eudoxtcsfalse      }
\newif\ifeudoxlayout   \bool_if:NTF \g_eudox_layout_bool   { \eudoxlayouttrue   } { \eudoxlayoutfalse   }

\ExplSyntaxOff

