%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Paragraph headings
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\newif\ifedxhaspunct

\newcommand{\edxcheckpunct}[1]{%
  \ifx\edxcheckpunct#1\edxcheckpunct\else\edxhaspuncttrue\fi
}

\def\edxcheckdot#1.\edxsep#2\edxend{\edxcheckpunct{#2}}
\def\edxcheckquestion#1?\edxsep#2\edxend{\edxcheckpunct{#2}}
\def\edxcheckexclam#1!\edxsep#2\edxend{\edxcheckpunct{#2}}
\def\edxcheckcolon#1:\edxsep#2\edxend{\edxcheckpunct{#2}}

\newcommand{\edxappendpunct}[1]{%
  \edxhaspunctfalse
  \edxcheckdot#1\edxsep.\edxsep\edxend
  \edxcheckquestion#1\edxsep?\edxsep\edxend
  \edxcheckexclam#1\edxsep!\edxsep\edxend
  \edxcheckcolon#1\edxsep:\edxsep\edxend
  #1\ifedxhaspunct\else.\fi
}

\newcommand{\edxeatnewline}{%
  \begingroup\catcode13=10\endgroup
}

\NewDocumentCommand{\parhead}{m}{%
  \smallskip\noindent
  \textbf{\boldmath\ignorespaces\edxappendpunct{#1}}~\edxeatnewline
}

\NewDocumentCommand{\subparhead}{m}{%
  \smallskip\noindent
  \textsc{\ignorespaces\edxappendpunct{#1}}~\edxeatnewline
}

\let\paragraph\parhead
\let\subparagraph\subparhead

