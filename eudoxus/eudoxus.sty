\pdfstringdefDisableCommands{%
\def\S{\textsection}%
\def\langle{<}\def\rangle{>}%
\def\lceil{[}\def\rceil{]}%
\def\left{}\def\right{}%
\def\lfloor{[}\def\rfloor{]}%
\def\mathbb#1{#1}%
\def\mathbf#1{#1}%
\def\mathcal#1{#1}%
\def\mathfrak#1{#1}%
\def\mathrm#1{#1}%
\def\mathscr#1{#1}%
\def\mathsf#1{#1}%
