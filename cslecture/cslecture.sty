\newif\ifcs@haspunct
\def\cs@checkchar#1{\ifx\cs@checkchar#1\cs@checkchar\else\cs@haspuncttrue\fi}
\def\cs@testdot   #1.\cs@e#2\cs@s  {\cs@checkchar{#2}}
\def\cs@testquest #1?\cs@e#2\cs@s  {\cs@checkchar{#2}}
\def\cs@testexclam#1!\cs@e#2\cs@s  {\cs@checkchar{#2}}
\def\cs@testcolon #1:\cs@e#2\cs@s  {\cs@checkchar{#2}}

\newcommand{\cs@autopunct}[1]{%
	\cs@haspunctfalse
	\cs@testdot   #1\cs@e.\cs@e\cs@s
	\cs@testquest #1\cs@e?\cs@e\cs@s
	\cs@testexclam#1\cs@e!\cs@e\cs@s
	\cs@testcolon #1\cs@e:\cs@e\cs@s
	#1\ifcs@haspunct\else.\fi}

\def\cs@skip{\begingroup\catcode13=10\@ifnextchar\relax{\endgroup}{\endgroup}}

\NewDocumentCommand{\parhead}{m}{%
	\smallskip\noindent{\bfseries\boldmath\ignorespaces\cs@autopunct{#1}}%
	\hskip 0.9em plus 0.3em minus 0.3em\cs@skip}

\NewDocumentCommand{\subparhead}{m}{%
	\smallskip\noindent{\scshape\ignorespaces\cs@autopunct{#1}}%
	\hskip 0.9em plus 0.3em minus 0.3em\cs@skip}

\long\def\cs@CustomFBox#1#2#3#4#5#6#7#8#9{%
	\leavevmode\begingroup
	\setbox\@tempboxa\hbox{%
		\color@begingroup\kern\fboxsep{#9}\kern\fboxsep\color@endgroup}%
	\hbox{\begingroup
		\@tempdima#4\relax
		\advance\@tempdima\fboxsep
		\advance\@tempdima\dp\@tempboxa
		\expandafter\endgroup\expandafter
		\lower\the\@tempdima\hbox{\vbox{%
				\hrule\@height#3\@width#7\relax#1%
				\hbox{\vrule\@width#5\relax\hspace{#8}%
					\vbox{\vskip\fboxsep\copy\@tempboxa\vskip\fboxsep}%
					\vrule\@width#6\relax}%
				#2\hrule\@height#4\@width#7\relax}}}%
	\endgroup}

\def\cs@OpenFBox#1#2{%
	\fboxsep\FrameSep
	\cs@CustomFBox{}{}{#1}{#2}\FrameRule\z@{1em}{0.5em}}

\newenvironment{nestedbar}[1][\hsize]{%
	\@ifundefined{OuterFrameSep}{%
		\@latex@error{nestedbar~requires~a~recent~framed.sty}\@ehd}{}%
	\def\FrameCommand     {\cs@OpenFBox\FrameRule\FrameRule}%
	\def\FirstFrameCommand{\cs@OpenFBox\FrameRule\z@}%
	\def\MidFrameCommand  {\cs@OpenFBox\z@\z@}%
	\def\LastFrameCommand {\cs@OpenFBox\z@\FrameRule}%
	\OuterFrameSep=1ex\FrameSep=0pt
	\MakeFramed{\hsize#1\advance\hsize-\width\FrameRestore}%
}{\endMakeFramed}

\newcommand{\course}  [1]{\def\@course{#1}}
\newcommand{\lecturer}[1]{\def\@lecturer{#1}}

\renewcommand{\maketitle}{%
	\thispagestyle{plain}%
	\@ifundefined{mdframed}{
		\noindent\rule{\linewidth}{0.4pt}\par\smallskip
		\noindent{\Large\bfseries\@title}\par\medskip
		\noindent
		\@ifundefined{@author}  {}{\textbf{Author:}~\@author}\hfill
		\@ifundefined{@date}    {}{\textbf{Date:}~\@date}\par
		\noindent
		\@ifundefined{@lecturer}{}{\textbf{Lecturer:}~\@lecturer}\hfill
		\@ifundefined{@course}  {}{\textbf{Course:}~\@course}\par\smallskip
		\noindent\rule{\linewidth}{0.4pt}\par\bigskip
	}{
		\begin{mdframed}[style=cs@titleblock]
			\noindent{\Large\bfseries\boldmath\@title}\par\vskip 0.8em
			\noindent\footnotesize
			\@ifundefined{@author}  {}{\textbf{Author:}~\@author}\hfill
			\@ifundefined{@date}    {}{\textbf{Date:}~\@date}\par\vskip 0.4em
			\noindent
			\@ifundefined{@lecturer}{}{\textbf{Lecturer:}~\@lecturer}\hfill
			\@ifundefined{@course}  {}{\textbf{Course:}~\@course}
		\end{mdframed}
		\bigskip
	}
}

