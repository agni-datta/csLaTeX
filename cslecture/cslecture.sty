\ExplSyntaxOn
\declaretheorem
[
    style        = cs@thmlike ,
    name         = Theorem ,
    numberwithin = section
]{ theorem }

\cs_new_protected:Npn \cslc_declare:nn #1#2 {
    \str_set:Nx \l_tmpa_str { \str_lowercase:n {#2} }
    \cs_if_exist:cTF {declaretheorem} {
        \use:x { \exp_not:N \declaretheorem [style=#1, name=#2, sibling=theorem] { \l_tmpa_str } }
    } {}
}

\clist_map_inline:nn {
    Assertion, Assumption, Axiom, Claim, Conclusion, Conjecture,
    Corollary, Criterion, Fact, Folklore, Hypothesis, Lemma,
    Observation, Postulate, Property, Proposition
}{ \cslc_declare:nn {cs@thmlike} {#1} }

\clist_map_inline:nn {
    Application, Construction, Convention, Definition, Example,
    Experiment, Notation, Problem, Protocol, Result
}{ \cslc_declare:nn {cs@deflike} {#1} }

\clist_map_inline:nn {
    Commentary, Exercise, Motivation, Note, Question, Remark
}{ \cslc_declare:nn {cs@remarklike} {#1} }

\clist_map_inline:nn {
    Guideline, Important, Insight, Recall, Summary, Tip, Warning
}{ \cslc_declare:nn {cs@hltlike} {#1} }

\declaretheorem
[
    style   = cs@remarklike ,
    name    = { Notation~Abuse } ,
    sibling = theorem
]{ notationabuse }
\declaretheorem
[
    style   = cs@remarklike ,
    name    = { Open~Problem } ,
    sibling = theorem
]{ openproblem }
\declaretheorem
[
    style   = cs@hltlike ,
    name    = { Key~Point } ,
    sibling = theorem
]{ keypoint }

\clist_map_inline:nn { Theorem, Lemma, Corollary, Claim, Conjecture, Hypothesis }{
    \str_set:Nx \l_tmpa_str { \str_lowercase:n {#1} }
    \cs_if_exist:cTF {declaretheorem} {
        \use:x { \exp_not:N \declaretheorem [style=cs@thmlike, name=#1, numbered=no] { \l_tmpa_str * } }
    } { }
}

\ExplSyntaxOff

\NewDocumentEnvironment{proofsketch}{o}
{
    \IfNoValueTF{#1}
    { \begin{proof}[Proof~(Sketch)] }
    { \begin{proof}[Proof~(Sketch~#1)] }
}
{ \end{proof} }

\NewDocumentEnvironment{proofidea}{o}
{
    \IfNoValueTF{#1}
    { \begin{proof}[Proof~(Idea)] }
    { \begin{proof}[Proof~(Idea~#1)] }
}
{ \end{proof} }

\NewDocumentEnvironment{proofofclaim}{o}
{
    \IfNoValueTF{#1}
    { \begin{proof}[Proof~of~Claim] }
    { \begin{proof}[Proof~of~Claim~(#1)] }
}
{ \end{proof} }

\AtBeginDocument{%
    \ProvideDocumentCommand{\theHtheorem}{}{\theHsection.\arabic{theorem}}%
}

