\mdfdefinestyle{cs@ruled}{
    linewidth         = 0.5pt ,
    topline           = true  ,
    bottomline        = true  ,
    leftline          = false ,
    rightline         = false ,
    innertopmargin    = 7.5pt ,
    innerbottommargin = 7.5pt ,
    innerleftmargin   = 0pt   ,
    innerrightmargin  = 0pt   ,
    skipabove         = 0.75\baselineskip ,
    skipbelow         = 0.75\baselineskip ,
}

\mdfdefinestyle{cs@titleblock}{
    linewidth         = 0.5pt ,
    linecolor         = black ,
    backgroundcolor   = gray!1 ,
    roundcorner       = 1pt   ,
    innertopmargin    = 12pt  ,
    innerbottommargin = 12pt  ,
    innerleftmargin   = 12pt  ,
    innerrightmargin  = 12pt  ,
    skipabove         = 0pt   ,
    skipbelow         = 20pt  ,
}

\declaretheoremstyle
[
    headfont      = \scshape ,
    notefont      = \normalfont ,
    bodyfont      = \normalfont ,
    spaceabove    = 0pt ,
    spacebelow    = 0pt ,
    headpunct     = {.} ,
    postheadspace = 0.5em ,
    mdframed      = { style = cs@ruled } ,
    qed           = \cs@endsymb ,
]{cs@thmlike}

\declaretheoremstyle
[
    headfont      = \scshape ,
    notefont      = \normalfont ,
    bodyfont      = \normalfont ,
    spaceabove    = 0pt ,
    spacebelow    = 0pt ,
    headpunct     = {.} ,
    postheadspace = 0.5em ,
    mdframed      = { style = cs@ruled } ,
    qed           = \cs@endsymb ,
]{cs@deflike}

\declaretheoremstyle
[
    headfont      = \scshape ,
    notefont      = \normalfont ,
    bodyfont      = \normalfont ,
    spaceabove    = 0pt ,
    spacebelow    = 0pt ,
    headpunct     = {.} ,
    postheadspace = 0.5em ,
    mdframed      = { style = cs@ruled } ,
    qed           = \cs@endsymb ,
]{cs@remarklike}

\declaretheoremstyle
[
    headfont      = \sffamily ,
    notefont      = \normalfont ,
    bodyfont      = \normalfont\sffamily ,
    spaceabove    = 0pt ,
    spacebelow    = 0pt ,
