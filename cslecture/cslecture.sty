\seq_new:N   \l_cslc_cref_seq

\clist_set:Nn \l_cslc_cref_clist {
    section       / \textsection  / \textsection\textsection / \textsection / \textsection\textsection ,
    subsection    / \textsection  / \textsection\textsection / \textsection / \textsection\textsection ,
    subsubsection / \textsection  / \textsection\textsection / \textsection / \textsection\textsection ,
    paragraph     / paragraph     / paragraphs      / Paragraph     / Paragraphs ,
    theorem       / theorem       / theorems        / Theorem       / Theorems ,
    assertion     / assertion     / assertions      / Assertion     / Assertions ,
    assumption    / assumption    / assumptions     / Assumption    / Assumptions ,
    axiom         / axiom         / axioms          / Axiom         / Axioms ,
    claim         / claim         / claims          / Claim         / Claims ,
    conclusion    / conclusion    / conclusions     / Conclusion    / Conclusions ,
    conjecture    / conjecture    / conjectures     / Conjecture    / Conjectures ,
    corollary     / corollary     / corollaries     / Corollary     / Corollaries ,
    criterion     / criterion     / criteria        / Criterion     / Criteria ,
    fact          / fact          / facts           / Fact          / Facts ,
    folklore      / folklore      / folklore        / Folklore      / Folklore ,
    hypothesis    / hypothesis    / hypotheses      / Hypothesis    / Hypotheses ,
    lemma         / lemma         / lemmas          / Lemma         / Lemmas ,
    observation   / observation   / observations    / Observation   / Observations,
    postulate     / postulate     / postulates      / Postulate     / Postulates ,
    property      / property      / properties      / Property      / Properties ,
    proposition   / proposition   / propositions    / Proposition   / Propositions,
    application   / application   / applications    / Application   / Applications,
    construction  / construction  / constructions   / Construction  / Constructions,
    convention    / convention    / conventions     / Convention    / Conventions ,
    definition    / definition    / definitions     / Definition    / Definitions ,
    example       / example       / examples        / Example       / Examples ,
    experiment    / experiment    / experiments     / Experiment    / Experiments ,
    notation      / notation      / notations       / Notation      / Notations   ,
    problem       / problem       / problems        / Problem       / Problems    ,
    protocol      / protocol      / protocols       / Protocol      / Protocols   ,
    result        / result        / results         / Result        / Results     ,
    commentary    / commentary    / commentaries    / Commentary    / Commentaries,
    exercise      / exercise      / exercises       / Exercise      / Exercises   ,
    motivation    / motivation    / motivations     / Motivation    / Motivations ,
    note          / note          / notes           / Note          / Notes       ,
    question      / question      / questions       / Question      / Questions   ,
    remark        / remark        / remarks         / Remark        / Remarks     ,
    guideline     / guideline     / guidelines      / Guideline     / Guidelines  ,
    important     / important~point / important~points / Important~Point / Important Points,
    insight       / insight       / insights        / Insight       / Insights    ,
    recall        / recall        / recalls         / Recall        / Recalls     ,
    summary       / summary       / summaries       / Summary       / Summaries   ,
    tip           / tip           / tips            / Tip           / Tips        ,
    warning       / warning       / warnings        / Warning       / Warnings    ,
    proof         / proof         / proofs          / Proof         / Proofs      ,
}

\clist_map_inline:Nn \l_cslc_cref_clist {
        \seq_set_split:Nnn \l_cslc_cref_seq { / } { #1 }
        \seq_pop_left:NN \l_cslc_cref_seq \l_tmpa_tl
        \seq_pop_left:NN \l_cslc_cref_seq \l_tmpb_tl
        \seq_pop_left:NN \l_cslc_cref_seq \l_tmpc_tl
        \seq_pop_left:NN \l_cslc_cref_seq \l_tmpd_tl
        \seq_pop_left:NN \l_cslc_cref_seq \l_tmpe_tl
        \use:e
        {
            \exp_not:N \crefname
            { \exp_not:V \l_tmpa_tl }
            { \exp_not:V \l_tmpb_tl }
            { \exp_not:V \l_tmpc_tl }
        }
        \use:e
        {
            \exp_not:N \Crefname
            { \exp_not:V \l_tmpa_tl }
            { \exp_not:V \l_tmpd_tl }
            { \exp_not:V \l_tmpe_tl }
        }
    }
    \Crefname{important}    {Important}     {Important Points}
    \Crefname{keypoint}     {Key~Point}     {Key~Points}
    \Crefname{notationabuse}{Notation~Abuse}{Notation~Abuses}
    \Crefname{openproblem}  {Open~Problem}  {Open~Problems}

\ExplSyntaxOff

