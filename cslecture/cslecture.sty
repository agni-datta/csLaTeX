\clist_map_inline:Nn \lcslc_cref_list {
	\seq_set_split:Nnn \lcslc_cref_seq { / } { #1 }
	\tl_set:Nx \l_tmpa_tl { \seq_item:Nn \lcslc_cref_seq {1} }
	\tl_set:Nx \l_tmpb_tl { \seq_item:Nn \lcslc_cref_seq {2} }
	\tl_set:Nx \l_tmpc_tl { \seq_item:Nn \lcslc_cref_seq {3} }
	\tl_set:Nx \l_tmpd_tl { \seq_item:Nn \lcslc_cref_seq {4} }
	\tl_set:Nx \l_tmpe_tl { \seq_item:Nn \lcslc_cref_seq {5} }

	\use:x { \exp_not:N \crefname { \l_tmpa_tl } { \l_tmpb_tl } { \l_tmpc_tl } }
	\use:x { \exp_not:N \Crefname { \l_tmpa_tl } { \l_tmpd_tl } { \l_tmpe_tl } }
}

